@model Comment
@*
    AddComment
*@


<div id="comments" class="comments-area  mt-45">
    <div id="respond" class="comment-respond">
        <h3 id="reply-title" class="comment-reply-title">Yorum Bırakın<small><a rel="nofollow" id="cancel-comment-reply-link" href="/finco/?p=2112#respond" style="display:none;">Cancel reply</a></small></h3>
        <form asp-action="AddComment" asp-controller="Blog" method="post" class="comment-form">

            <input type="hidden" asp-for="ArticleId" />

            <p class="comment-form-comment">
                <label>Yorumunuz</label>
                <textarea asp-for="CommentDetail" cols="45" rows="8"
                          placeholder="Buraya yorum yazabilirsiniz." required></textarea>
            </p>

            <p class="form-submit">
                <button type="submit" class="submit">Yorum Yap</button>
            </p>
        </form>
    </div>
 </div>