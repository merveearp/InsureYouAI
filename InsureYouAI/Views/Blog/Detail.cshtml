@model Article

@{
    ViewData["Title"] = "Blog Detay";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    

    .blog-hero {
        position: relative;
        height: 500px;
        overflow: hidden;
    }

        .blog-hero img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }


    .hero-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.6), rgba(0,0,0,0.3));
        display: flex;
        align-items: center;
    }


        .hero-overlay .container {
            position: relative;
        }


    .back-btn-hero {
        position: absolute;
        top: -60px;
        left: 0;
        background: #fff;
        color: #000;
        padding: 6px 12px;
        border-radius: 6px;
        font-size: 13px;
        text-decoration: none;
    }

    .hero-overlay h1 {
        color: #fff;
        font-size: 42px;
        font-weight: 800;
    }


    .blog-meta {
        color: #ddd;
        margin-top: 10px;
    }


    .blog-content {
        margin-top: -80px;
        background: #fff;
        padding: 40px;
        border-radius: 15px;
        box-shadow: 0 10px 40px rgba(0,0,0,0.1);
    }
</style>


<div class="blog-hero">

    <img src="@Model.MainCoverImageUrl" />

    <div class="hero-overlay">
        <div class="container">


            <a href="javascript:history.back()" class="back-btn-hero">
                <i class="bi bi-arrow-left"></i> Geri Dön
            </a>

            <h1>@Model.Title</h1>

            <div class="blog-meta">
                <span>Admin</span> •
                <span>@Model.CreatedDate.ToString("dd MMM yyyy")</span> •
                <span>@Model.Category?.CategoryName</span>
            </div>

        </div>
    </div>

</div>

<section class="pt-80 pb-80">
    <div class="container">


        <div class="back-btn">
            <a href="javascript:history.back()" class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Geri Dön
            </a>
        </div>

        <div class="blog-content">

      
            <div class="blog-text">

                @foreach (var line in Model.Content.Split('\n'))
                {
                    <p>@line</p>
                }

         
                @if (!string.IsNullOrEmpty(Model.CoverImageUrl))
                {
                    <div class="my-4">
                        <img src="@Model.CoverImageUrl" class="blog-inner-img" />
                    </div>
                }

            </div>

        </div>

    </div>
</section>