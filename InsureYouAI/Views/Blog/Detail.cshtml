@model Article

@{
    ViewData["Title"] = "Blog Detay";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<style>
    .comment-section {
        margin-top: 45px;
        margin-bottom: 45px;
    }

    .comment-section-title {
        margin-bottom: 28px;
    }

        .comment-section-title h5 {
            font-size: 28px;
            font-weight: 800;
            color: #00235a;
            margin-bottom: 6px;
        }

    .comment-card {
        display: flex;
        gap: 18px;
        padding: 24px;
        margin-bottom: 22px;
        border-radius: 20px;
        background: #ffffff;
        border: 1px solid #eef2f7;
        box-shadow: 0 10px 30px rgba(0, 35, 90, .05);
    }

    .comment-avatar {
        min-width: 56px;
        width: 56px;
        height: 56px;
        border-radius: 50%;
        overflow: hidden;
        background: #e9ffff;
        display: flex;
        align-items: center;
        justify-content: center;
    }

        .comment-avatar img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

    .comment-content {
        flex: 1;
    }

    .comment-header {
        display: flex;
        justify-content: space-between;
        gap: 12px;
        flex-wrap: wrap;
        margin-bottom: 10px;
    }

    .comment-user h6 {
        margin: 0;
        font-size: 16px;
        font-weight: 800;
        color: #00235a;
    }

    .comment-date {
        font-size: 12px;
        letter-spacing: 1.5px;
        text-transform: uppercase;
        color: #4d73ff;
        font-weight: 600;
    }

    .comment-message {
        margin: 0;
        color: #667085;
        font-size: 15px;
        line-height: 1.8;
    }

    .comment-reply-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        margin-top: 14px;
        padding: 8px 15px;
        border-radius: 30px;
        background: #f4f8ff;
        color: #00235a;
        font-size: 13px;
        font-weight: 700;
        text-decoration: none;
    }

        .comment-reply-btn:hover {
            background: #0d6efd;
            color: #ffffff;
        }

    .empty-comment-box {
        padding: 25px;
        border-radius: 18px;
        background: #f8fbff;
        border: 1px dashed #d9e3f0;
        color: #667085;
    }
</style>

<section class="breadcrumb-area d-flex align-items-center"
         style="
    background-image: url(@Model.MainCoverImageUrl);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    height: 555px;
    position: relative;
    ">


    <div style="
        position:absolute;
        inset:0;
        background: rgba(0,0,0,0.5);
        z-index:1;">
    </div>

</section>



<section class="inner-blog b-details-p pt-120 pb-120">
    <div class="container">


        <div class="container">
            <div class="row align-items-center">
                <div class="col-xl-12 col-lg-12">
                    <div class="breadcrumb-wrap text-left">
                        <div class="breadcrumb-title">
                            <div class="breadcrumb-wrap">
                              
                                <nav aria-label="breadcrumb">
                                    <ol class="breadcrumb">
                                        <li class="breadcrumb-item"><a href="/Blog/Index/">Blog Listesi</a></li>
                                        <li class="breadcrumb-item active" aria-current="page">@Model.Category.CategoryName</li>
                                    </ol>
                                </nav>
                            </div>
                        </div>
                    </div>
                </div>
                        
            </div>
        </div>


        <div class="row">
        
            <div class="col-lg-8">
              
                <div class="blog-details-wrap">
                       
                    <div class="details__content pb-30">
                        <h2>
                            @Model.Title
                        </h2>
                        <div class="meta-info">
                            <ul>
                                <li>
                                    <i class="fal fa-eye"></i> @Model.ViewCount Görüntülenme
                                </li>
                                <li><i class="fal fa-calendar-alt"></i> @Model.CreatedDate.ToString("dd-MMM-yyyy")</li>
                            </ul>
                        </div>
                        <p>@Html.Raw(Model.Content)</p>
 
                        <div class="details__content-img">
                            <img src="@Model.CoverImageUrl" alt="">
                        </div>

    
                        <div class="meta-info">
                            <ul>
                                <li> @Model.Category.CategoryName </li>
                                <li><i class="fal fa-user"></i> @Model.AppUser.Name @Model.AppUser.Surname</li>
                                <li><i class="fal fa-comments"></i> @Model.Comments.Count()</li>
                            </ul>
                        </div>
    
                        <div class="row">
                            <div class="col-xl-12 col-md-12">
                                <div class="post__tag">
                                    <h5>Releted Tags</h5>
                                    <ul>
                                        <li><a href="#">organic</a></li>
                                        <li><a href="#">Foods</a></li>
                                        <li><a href="#">tasty</a></li>
                                    </ul>
                                </div>
                            </div>
                                        
                        </div>
                    </div>
                    <div class="clearfix mb-5">
                        @await Component.InvokeAsync("_UIBlogDetailNextEndPrevPostComponent", new { id = Model.ArticleId })
                    </div>

                    <div class="mt-5">
                        @await Component.InvokeAsync("_UIBlogDetailAuthorAboutComponent",new { id = Model.ArticleId })
                    </div>

                    <div class="comment-section">
                        <div class="comment-section-title">
                            <h5>Yorumlar</h5>
                            <p class="text-muted mb-0">
                                Bu yazıya yapılan kullanıcı yorumları
                            </p>
                        </div>

                        @if (Model.Comments != null && Model.Comments.Any())
                        {
                            foreach (var item in Model.Comments)
                            {
                                <div class="comment-card">

                                    <div class="comment-avatar">
                                        @if (!string.IsNullOrEmpty(item.AppUser?.ImageUrl))
                                        {
                                            <img src="@item.AppUser.ImageUrl" alt="@item.AppUser.Name @item.AppUser.Surname">
                                        }
                                        else
                                        {
                                            <i class="bi bi-person-fill"></i>
                                        }
                                    </div>

                                    <div class="comment-content">
                                        <div class="comment-header">
                                            <div class="comment-user">
                                                <h6>@item.AppUser.Name @item.AppUser.Surname</h6>
                                                <span class="comment-date">
                                                    @item.CommentDate.ToString("dd MMM yyyy")
                                                </span>
                                            </div>
                                        </div>

                                        <p class="comment-message">
                                            @item.CommentDetail
                                        </p>

                                        <a href="#" class="comment-reply-btn">
                                            <i class="fas fa-reply"></i>
                                            Yanıtla
                                        </a>
                                    </div>

                                </div>
                            }
                        }
                        else
                        {
                            <div class="empty-comment-box">
                                Henüz yorum yapılmamış. İlk yorumu sen bırakabilirsin.
                            </div>
                        }
                    </div>
                    
                    @await Html.PartialAsync("/Views/Blog/AddComment.cshtml", new Comment { ArticleId = Model.ArticleId })

                </div>
            </div>
             
            
            <div class="col-sm-12 col-md-12 col-lg-4">
                <aside class="sidebar-widget">

                    @await Html.PartialAsync("~/Views/Blog/GetBlog.cshtml")
                 
                    @await Component.InvokeAsync("_UIBlogMediaComponent")
                    @await Component.InvokeAsync("_UIBlogCategoryComponent")
                 
                    @await Component.InvokeAsync("_UIBlogRecentPostComponent")
                    @await Component.InvokeAsync("_UIBlogTagComponent")
                   
                   
                </aside>
            </div>
    
        </div>
    </div>
</section>

@await Html.PartialAsync("~/Views/Home/SubscribeEmail.cshtml")