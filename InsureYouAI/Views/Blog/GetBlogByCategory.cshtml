@model List<Article>
@{
    ViewData["Title"] = "Kategorilere Göre Bloglar";
    Layout = "~/Views/Shared/_Layout.cshtml";
}


<!-- breadcrumb-area -->
@await Component.InvokeAsync("_UIBlogListBreadCrumbComponent")
<!-- breadcrumb-area-end -->

<style>

    .custom-btn {
        display: inline-block;
        padding: 10px 22px;
        font-size: 14px;
        font-weight: 600;
        color: #fff;
        background: linear-gradient(135deg, #4facfe, #00f2fe);
        border-radius: 30px;
        text-decoration: none;
        transition: all 0.3s ease;
    }

        .custom-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(0,0,0,0.15);
            color: #fff;
        }
</style>

<section class="inner-blog pt-120 pb-120">
    <div class="container">
        <div class="row">
          

            <div class="col-lg-8">

                <div class="mt-3">
                    <a asp-controller="Blog"
                           asp-action="Index"
                           class="custom-btn">
                        <i class="fal fa-arrow-left"></i> Tüm Bloglara Dön
                    </a>
                </div>
                <div class="section-title mb-40">
                    <h3>@ViewBag.CategoryName</h3>
                    <h6>Bu kategoriye ait blog yazıları</h6>

                   
                </div>

                @foreach (var item in Model)
                {
                    <div class="bsingle__post mb-50">
                        <div class=bsingle__post-thumb">
                            <img src="@item.CoverImageUrl" alt="">
                        </div>
                        <div class="bsingle__content">
                            <div class="meta-info">
                                <ul>
                                    <li><i class="fal fa-user"></i>@item.AppUser.Name @item.AppUser.Surname</li>
                                    <li><i class="fal fa-calendar-alt"></i> @item.CreatedDate.ToString("dd-MMM-yyyy")</li>
                                    <li><i class="fal fa-folder-open"></i> @item.Category.CategoryName</li>
                                    <li><i class="fal fa-comments"></i> @item.Comments.Count() Yorum</li>
                                </ul>
                            </div>
                            <h2>
                                <a asp-controller="Blog" asp-action="Detail" asp-route-id="@item.ArticleId">
                                    @item.Title
                                </a>
                            </h2>
                            <p>
                                @Html.Raw(item.Content.Length > 300
                        ? item.Content.Substring(0, 300) + "..."
                        : item.Content)
                            </p>
                            <div class="blog__btn">
                                <a asp-controller="Blog" asp-action="Detail" asp-route-id="@item.ArticleId" class="custom-btn">Devamını Oku</a>
                            </div>
                        </div>
                    </div>
  


                }

               
            </div>

            <div class="col-sm-12 col-md-12 col-lg-4">
                <aside class="sidebar-widget">

                    @await Html.PartialAsync("~/Views/Blog/GetBlog.cshtml")
                 
                    @await Component.InvokeAsync("_UIBlogMediaComponent")
                    @await Component.InvokeAsync("_UIBlogCategoryComponent")
                 
                    @await Component.InvokeAsync("_UIBlogRecentPostComponent")
                    @await Component.InvokeAsync("_UIBlogTagComponent")
                   
                   
                </aside>
            </div>
        </div>
    </div>
</section>


@await Html.PartialAsync("~/Views/Home/SubscribeEmail.cshtml")