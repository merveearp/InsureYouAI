@* _UIHomeAIHeroBannerComponent *@

<style>
    .ai-hero-banner {
        background-image: url('/images/insurekapak.jpeg');
        background-size: cover;
        background-position: center;
        height: 420px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
        position: relative;
    }

        .ai-hero-banner::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(135deg, rgba(13,110,253,0.75), rgba(0,0,0,0.65));
        }

        .ai-hero-banner .container {
            position: relative;
            z-index: 2;
        }

        .ai-hero-banner h1 {
            font-size: 46px;
            font-weight: 700;
            margin-bottom: 15px;
        }

        .ai-hero-banner p {
            font-size: 19px;
            max-width: 700px;
            margin: auto;
            margin-bottom: 30px;
        }

    .ai-btn {
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(8px);
        padding: 14px 28px;
        border-radius: 35px;
        color: white;
        margin: 6px;
        display: inline-block;
        border: 1px solid rgba(255,255,255,0.35);
        transition: all .35s ease;
    }

        .ai-btn:hover {
            background: white;
            color: #0d6efd;
            transform: translateY(-3px);
        }

    /* Chat */
    #chatBox {
        height: 400px;
        overflow-y: auto;
        background: #fafafa;
        border-radius: 10px;
    }
    .ai-chat-modal {
    height: 550px;
    border-radius: 20px;
    overflow: hidden;
    display: flex;
    flex-direction: column;
}


.ai-header {
    background: linear-gradient(135deg, #0d6efd, #4dabf7);
    color: white;
    padding: 18px;
    font-weight: 600;
    text-align: center;
}


.ai-chat-box {
    flex: 1;
    padding: 15px;
    overflow-y: auto;
    background: #f5f7fb;
}


.ai-input-area {
    display: flex;
    border-top: 1px solid #eee;
}

.ai-input-area input {
    flex: 1;
    border: none;
    padding: 15px;
    outline: none;
}

.ai-input-area button {
    background: #0d6efd;
    color: white;
    border: none;
    padding: 0 25px;
}
</style>

<section class="ai-hero-banner">
    <div class="container">

        <h1>AI Sigorta Zeka Merkezi</h1>

        <p>
            Sigorta süreçlerinizi yapay zeka destekli analiz araçları ile
            daha hızlı ve akıllı yönetin.
        </p>

        <button class="ai-btn" data-bs-toggle="modal" data-bs-target="#aiModal">
            💡 AI Sigorta Danışmanı
        </button>

        <a href="/ClaimAnalysis" class="ai-btn">🛡️ AI Hasar Analizi</a>
        <a href="/PolicyReader" class="ai-btn">📄 AI Poliçe Okuyucu</a>

    </div>
</section>
<div class="modal fade" id="aiModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">

        <div class="modal-content ai-chat-modal">


            <div class="ai-header">
                💡 AI Sigorta Danışmanı
            </div>


            <div id="chatBox" class="ai-chat-box"></div>


            <div class="ai-input-area">
                <input type="text" id="message" placeholder="Mesajınızı yazın..." />
                <button onclick="sendMessage()">Gönder</button>
            </div>

        </div>
    </div>
</div>

<script>
    let chatHistory = [];

    function sendMessage() {

        let message = document.getElementById("message").value;
        if (!message) return;

        renderMessage("user", message);
        document.getElementById("message").value = "";

        fetch('/Home/GetConsultation', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: 'message=' + encodeURIComponent(message)
        })
        .then(res => res.json())
        .then(data => {
            renderMessage("ai", data.message);
        });
    }

       function renderMessage(sender, text) {

        let chatBox = document.getElementById("chatBox");

        let html = sender === "user"
            ? `<div style="text-align:right; margin-bottom:10px;">
                    <div style="
                        display:inline-block;
                        background:linear-gradient(135deg,#0d6efd,#4dabf7);
                        color:white;
                        padding:12px 16px;
                        border-radius:15px 15px 0 15px;
                        max-width:70%;
                    ">
                        ${text}
                    </div>
               </div>`
            : `<div style="text-align:left; margin-bottom:10px;">
                    <div style="
                        display:inline-block;
                        background:white;
                        padding:12px 16px;
                        border-radius:15px 15px 15px 0;
                        max-width:70%;
                        box-shadow:0 2px 6px rgba(0,0,0,0.1);
                    ">
                        ${text}
                    </div>
               </div>`;

        chatBox.innerHTML += html;
        chatBox.scrollTop = chatBox.scrollHeight;
    }

    document.addEventListener("DOMContentLoaded", function () {

            document.getElementById("message").addEventListener("keypress", function(e){
        if(e.key === "Enter"){
            sendMessage();
        }
    });


        document.getElementById('aiModal').addEventListener('shown.bs.modal', function () {

            if (chatHistory.length === 0) {
                renderMessage("ai", "Merhaba 👋 İhtiyacınıza en uygun sigorta poliçesini belirlemek için size yardımcı olabilirim. Kısaca ihtiyacınızı paylaşabilirsiniz.");
            }
        });

        document.getElementById('aiModal').addEventListener('hidden.bs.modal', function () {

            chatHistory = [];
            document.getElementById("chatBox").innerHTML = "";
        });
    });
</script>