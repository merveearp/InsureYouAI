@* _UIHomeAIHeroBannerComponent *@
@* _UIHomeAIHeroBannerComponent *@

<style>
    /* ── Hero Banner ── */
    .ai-hero-banner {
        background-image: url('/images/insurekapak.jpeg');
        background-size: cover;
        background-position: center;
        height: 420px;
        display: flex;
        align-items: center;
        justify-content: center;
        text-align: center;
        color: white;
        position: relative;
    }
    .ai-hero-banner::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(135deg, rgba(13,110,253,0.75), rgba(0,0,0,0.65));
    }
    .ai-hero-banner .container {
        position: relative;
        z-index: 2;
    }
    .ai-hero-banner h1 {
        font-size: 46px;
        font-weight: 700;
        margin-bottom: 15px;
    }
    .ai-hero-banner p {
        font-size: 19px;
        max-width: 700px;
        margin: auto;
        margin-bottom: 30px;
    }
    .ai-btn {
        background: rgba(255,255,255,0.15);
        backdrop-filter: blur(8px);
        padding: 14px 28px;
        border-radius: 35px;
        color: white;
        margin: 6px;
        display: inline-block;
        border: 1px solid rgba(255,255,255,0.35);
        transition: all .35s ease;
        text-decoration: none;
    }
    .ai-btn:hover {
        background: white;
        color: #0d6efd;
        transform: translateY(-3px);
        text-decoration: none;
    }

    /* ── Modal ── */
    .ai-chat-modal {
        border-radius: 20px;
        overflow: hidden;
        border: none;
    }
    .modal-content.ai-chat-modal {
        height: 620px;
        display: flex;
        flex-direction: column;
    }

    .ai-modal-header {
        background: #0d6efd;
        padding: 0 20px;
        height: 64px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        flex-shrink: 0;
    }
    .ai-header-left {
        display: flex;
        align-items: center;
        gap: 10px;
    }
    .ai-header-avatar {
        width: 36px;
        height: 36px;
        background: rgba(255,255,255,0.18);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1.5px solid rgba(255,255,255,0.35);
        flex-shrink: 0;
    }
    .ai-header-avatar svg {
        width: 18px;
        height: 18px;
    }
    .ai-header-title {
        font-size: 14px;
        font-weight: 600;
        color: #ffffff;
        line-height: 1.3;
    }
    .ai-header-sub {
        font-size: 11px;
        color: rgba(255,255,255,0.72);
        display: flex;
        align-items: center;
        gap: 5px;
        margin-top: 1px;
    }
    .ai-online-dot {
        width: 7px;
        height: 7px;
        background: #4ade80;
        border-radius: 50%;
        display: inline-block;
        flex-shrink: 0;
    }
    .ai-modal-close {
        width: 30px;
        height: 30px;
        background: rgba(255,255,255,0.15);
        border: none;
        border-radius: 50%;
        color: white;
        font-size: 15px;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background .2s;
        line-height: 1;
    }
    .ai-modal-close:hover {
        background: rgba(255,255,255,0.28);
    }


    .ai-chat-box {
        flex: 1;
        overflow-y: auto;
        padding: 18px 14px;
        background: #f0f4f9;
        display: flex;
        flex-direction: column;
        gap: 12px;
    }
    .ai-chat-box::-webkit-scrollbar { width: 4px; }
    .ai-chat-box::-webkit-scrollbar-track { background: transparent; }
    .ai-chat-box::-webkit-scrollbar-thumb { background: #c5d0de; border-radius: 4px; }

    .ai-date-divider {
        text-align: center;
        font-size: 11px;
        color: #9aa5b4;
        display: flex;
        align-items: center;
        gap: 8px;
        margin: 4px 0;
    }
    .ai-date-divider::before,
    .ai-date-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: #dde3ec;
    }

    .ai-msg-row {
        display: flex;
        align-items: flex-end;
        gap: 8px;
    }
    .ai-msg-row.ai-user {
        flex-direction: row-reverse;
    }
    .ai-bot-ava {
        width: 28px;
        height: 28px;
        background: #0d6efd;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        margin-bottom: 2px;
    }
    .ai-bot-ava svg { width: 14px; height: 14px; }

    .ai-bubble {
        max-width: 74%;
        padding: 10px 14px;
        font-size: 13.5px;
        line-height: 1.6;
        word-break: break-word;
    }
    .ai-bubble.ai-bot-bubble {
        background: #ffffff;
        color: #1a2332;
        border-radius: 16px 16px 16px 4px;
        border: 0.5px solid #e2e8f0;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .ai-bubble.ai-user-bubble {
        background: #0d6efd;
        color: #ffffff;
        border-radius: 16px 16px 4px 16px;
    }
    .ai-bubble.ai-user-bubble .ai-msg-time {
        color: rgba(255,255,255,0.65);
    }
    .ai-bubble ol, .ai-bubble ul {
        padding-left: 18px;
        margin: 8px 0;
    }
    .ai-bubble li { margin-bottom: 4px; }
    .ai-msg-time {
        font-size: 10px;
        color: #9aa5b4;
        margin-top: 5px;
        display: block;
        text-align: right;
    }


    #aiTypingIndicator .ai-typing-bubble {
        background: #ffffff;
        border: 0.5px solid #e2e8f0;
        border-radius: 16px 16px 16px 4px;
        padding: 12px 16px;
        display: flex;
        align-items: center;
        gap: 5px;
        box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    }
    .ai-dot {
        width: 7px; height: 7px;
        background: #94a3b8;
        border-radius: 50%;
        animation: aiDotBounce 1.2s infinite;
    }
    .ai-dot:nth-child(2) { animation-delay: .2s; }
    .ai-dot:nth-child(3) { animation-delay: .4s; }
    @@keyframes aiDotBounce {
        0%,60%,100% { transform: translateY(0); opacity: .5; }
        30%          { transform: translateY(-6px); opacity: 1; }
    }

    /* ── Quick Chips ── */
    .ai-chips {
        display: flex;
        flex-wrap: wrap;
        gap: 6px;
        margin-top: 10px;
    }
    .ai-chip {
        background: #eff6ff;
        border: 0.5px solid #bfdbfe;
        color: #1d4ed8;
        font-size: 12px;
        padding: 5px 12px;
        border-radius: 20px;
        cursor: pointer;
        transition: background .18s;
        white-space: nowrap;
    }
    .ai-chip:hover { background: #dbeafe; }

    /* ── Input Bar ── */
    .ai-input-bar {
        display: flex;
        align-items: center;
        gap: 10px;
        padding: 12px 14px;
        background: #ffffff;
        border-top: 1px solid #e8edf4;
        flex-shrink: 0;
    }
    .ai-msg-input {
        flex: 1;
        background: #f8fafc;
        border: 1px solid #e2e8f0;
        border-radius: 22px;
        padding: 10px 18px;
        font-size: 13.5px;
        color: #1a2332;
        outline: none;
        transition: border .18s, background .18s;
        font-family: inherit;
    }
    .ai-msg-input:focus {
        border-color: #93c5fd;
        background: #fff;
    }
    .ai-msg-input::placeholder { color: #9aa5b4; }
    .ai-send-btn {
        width: 40px; height: 40px;
        background: #0d6efd;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        flex-shrink: 0;
        transition: background .18s, transform .18s;
    }
    .ai-send-btn:hover {
        background: #0b5ed7;
        transform: scale(1.06);
    }
    .ai-send-btn svg { width: 16px; height: 16px; }
</style>


<section class="ai-hero-banner">
    <div class="container">
        <h1>AI Sigorta Zeka Merkezi</h1>
        <p>Sigorta süreçlerinizi yapay zeka destekli analiz araçları ile daha hızlı ve akıllı yönetin.</p>
        <button class="ai-btn" data-bs-toggle="modal" data-bs-target="#aiModal">
            💡 AI Sigorta Danışmanı
        </button>
        <a href="/AIAnalysis/Index" class="ai-btn">🛡️ AI Hasar Analizi</a>
        <a href="/AIPolicy/Index" class="ai-btn">📄 AI Poliçe Okuyucu</a>
    </div>
</section>


<div class="modal fade" id="aiModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content ai-chat-modal">


            <div class="ai-modal-header">
                <div class="ai-header-left">
                    <div class="ai-header-avatar">
                        <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2"
                             stroke-linecap="round" stroke-linejoin="round">
                            <circle cx="12" cy="8" r="4"/>
                            <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
                        </svg>
                    </div>
                    <div>
                        <div class="ai-header-title">AI Sigorta Danışmanı</div>
                        <div class="ai-header-sub">
                            <span class="ai-online-dot"></span>
                            Çevrimiçi · Hemen yanıt veriyor
                        </div>
                    </div>
                </div>
                <button class="ai-modal-close" data-bs-dismiss="modal">✕</button>
            </div>


            <div class="ai-chat-box" id="chatBox"></div>


            <div class="ai-input-bar">
                <input class="ai-msg-input" id="message" type="text" placeholder="Mesajınızı yazın..." />
                <button class="ai-send-btn" onclick="sendMessage()">
                    <svg viewBox="0 0 24 24" fill="white">
                        <path d="M2.01 21L23 12 2.01 3 2 10l15 2-15 2z"/>
                    </svg>
                </button>
            </div>

        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
<script>
    const connection = new signalR.HubConnectionBuilder()
        .withUrl("/insuranceChatHub")
        .build();

    connection.start()
        .then(() => console.log("SignalR bağlandı"))
        .catch(err => console.error(err));

    function now() {
        const d = new Date();
        return d.getHours() + ':' + String(d.getMinutes()).padStart(2, '0');
    }

    function markdownToHtml(text) {
        return text
            .replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>')
            .replace(/\*(.*?)\*/g, '<em>$1</em>')
            .replace(/^\d+\.\s+(.+)$/gm, '<li>$1</li>')
            .replace(/(<li>[\s\S]*?<\/li>(\n|$))+/g, m => `<ol>${m}</ol>`)
            .replace(/^[-*]\s+(.+)$/gm, '<li>$1</li>')
            .replace(/\n/g, '<br>');
    }

    function botAvatarHtml() {
        return `<div class="ai-bot-ava">
            <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.2"
                 stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="8" r="4"/>
                <path d="M4 20c0-4 3.6-7 8-7s8 3 8 7"/>
            </svg>
        </div>`;
    }

    function renderMessage(sender, text, chips) {
        const chatBox = document.getElementById("chatBox");
        const row = document.createElement("div");
        row.className = "ai-msg-row" + (sender === "user" ? " ai-user" : "");

        let chipsHtml = "";
        if (chips && chips.length) {
            chipsHtml = `<div class="ai-chips">` +
                chips.map(c => `<span class="ai-chip" onclick="sendChip(this)">${c}</span>`).join("") +
                `</div>`;
        }

        if (sender === "user") {
            row.innerHTML = `
                <div class="ai-bubble ai-user-bubble">
                    ${text}
                    <span class="ai-msg-time">${now()}</span>
                </div>`;
        } else {
            row.innerHTML = `
                ${botAvatarHtml()}
                <div class="ai-bubble ai-bot-bubble">
                    ${markdownToHtml(text)}
                    ${chipsHtml}
                    <span class="ai-msg-time">${now()}</span>
                </div>`;
        }

        chatBox.appendChild(row);
        chatBox.scrollTop = chatBox.scrollHeight;
    }

    function addTypingIndicator() {
        const chatBox = document.getElementById("chatBox");
        const row = document.createElement("div");
        row.className = "ai-msg-row";
        row.id = "aiTypingIndicator";
        row.innerHTML = `
            ${botAvatarHtml()}
            <div class="ai-typing-bubble">
                <div class="ai-dot"></div>
                <div class="ai-dot"></div>
                <div class="ai-dot"></div>
            </div>`;
        chatBox.appendChild(row);
        chatBox.scrollTop = chatBox.scrollHeight;
    }

    function removeTypingIndicator() {
        const el = document.getElementById("aiTypingIndicator");
        if (el) el.remove();
    }

    function sendMessage() {
        const input = document.getElementById("message");
        const msg = input.value.trim();
        if (!msg) return;
        renderMessage("user", msg);
        input.value = "";
        connection.invoke("SendMessage", msg).catch(err => console.error(err));
    }

    function sendChip(el) {
        const text = el.textContent;
        el.closest(".ai-chips").remove();
        renderMessage("user", text);
        connection.invoke("SendMessage", text).catch(err => console.error(err));
    }

    connection.on("Typing", function () {
        removeTypingIndicator();
        addTypingIndicator();
    });

    connection.on("ReceiveAIMessage", function (msg) {
        removeTypingIndicator();
        renderMessage("ai", msg);
    });

    document.addEventListener("DOMContentLoaded", function () {
        document.getElementById("message").addEventListener("keypress", function (e) {
            if (e.key === "Enter") sendMessage();
        });

        document.getElementById("aiModal").addEventListener("shown.bs.modal", function () {
            if (document.getElementById("chatBox").innerHTML.trim() === "") {
                renderMessage("ai",
                    "Merhaba! 👋 Size en uygun sigorta poliçesini bulmak için buradayım. Nasıl yardımcı olabilirim?",
                    ["Konut sigortası", "Kasko & trafik", "Sağlık sigortası"]
                );
            }
        });

        document.getElementById("aiModal").addEventListener("hidden.bs.modal", function () {
            document.getElementById("chatBox").innerHTML = "";
            removeTypingIndicator();
        });
    });
</script>