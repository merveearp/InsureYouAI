@model List<PricingPlan>

    <style>


        .pricing-box-modern {
    background: #ffffff;
    border-radius: 20px;
    padding: 30px;
    box-shadow: 0 10px 30px rgba(0,0,0,0.08);
    transition: 0.3s;
    height: 100%;
}

.pricing-box-modern:hover {
    transform: translateY(-10px);
    box-shadow: 0 20px 40px rgba(0,0,0,0.15);
}

.pricing-head h3 {
    font-weight: 600;
    margin-bottom: 15px;
}

.price-count h2 {
    font-size: 36px;
    font-weight: bold;
    color: #0d6efd;
}

.price-count span {
    font-size: 14px;
    color: #777;
}

.pricing-body ul {
    list-style: none;
    padding: 0;
    margin-top: 20px;
}

.pricing-body ul li {
    margin-bottom: 10px;
    font-size: 15px;
    display: flex;
    align-items: center;
    gap: 8px;
}

.pricing-btn {
    margin-top: 25px;
}
    </style>

<div class="container">
    <div class="row">

        @foreach (var item in Model)
        {
            <div class="col-lg-4 col-md-6 col-sm-12">
                <div class="pricing-box-modern mb-40">


                    <div class="pricing-head text-center">
                        <h3>@item.Title</h3>

                        <div class="price-count">
                            <h2>@item.Price ₺</h2>
                            <span>/ Aylık</span>
                        </div>
                    </div>

   
                    <div class="pricing-body">
                        <ul>
                            @if (item.PricingPlanItems != null && item.PricingPlanItems.Any())
                            {
                                foreach (var planItem in item.PricingPlanItems)
                                {
                                    <li>
                                        <i class="bi bi-check-circle-fill text-success"></i>
                                        @planItem.Title
                                    </li>
                                }
                            }
                            else
                            {
                                <li>Özellik bulunmamaktadır</li>
                            }
                        </ul>
                    </div>


                    <div class="pricing-btn text-center">
                        <a href="contact.html" class="btn btn-primary w-100">
                            Teklif Al
                        </a>
                    </div>

                </div>
            </div>
        }

    </div>
</div>