@model List<TrailerVideo>
@*
    _UIHomeVideoComponent
*@

<style>
    .s-video-wrap {
        position: relative;
        height: 420px;
        border-radius: 24px;
        overflow: hidden;
        background-size: cover;
        background-position: center;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.4s;
    }


    .s-video-wrap::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(0,0,0,0.3),
            rgba(0,0,0,0.75)
        );
        z-index: 1;
    }


    .s-video-content {
        position: relative;
        z-index: 2;
        text-align: center;

        max-width: 550px;
        margin: auto;
        padding: 35px;

        border-radius: 18px;


        background: rgba(0, 0, 0, 0.55);

        box-shadow: 0 10px 40px rgba(0,0,0,0.5);
        color: #fff;
    }

    .s-video-content h2 {
        font-size: 30px;
        font-weight: 700;
        margin-bottom: 10px;
    }

    .s-video-content p {
        font-size: 14px;
        opacity: 0.9;
        margin-bottom: 25px;
    }


    .popup-video {
        width: 60px;
        height: 60px;
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;

        background: linear-gradient(135deg, #4dabf7, #0d6efd);
        box-shadow: 0 0 25px rgba(13,110,253,0.6);

        transition: 0.3s;
        position: relative;
    }

.popup-video i {
    font-size: 55px;
    color: #fff;
    margin-left: 3px; 
}

    .popup-video::before {
        content: "";
        position: absolute;
        width: 100%;
        height: 100%;
        border-radius: 50%;
        background: rgba(13,110,253,0.4);
        animation: pulse 2s infinite;
        z-index: -1;
    }

    @@keyframes pulse {
        0% { transform: scale(1); opacity: 0.6; }
        100% { transform: scale(1.6); opacity: 0; }
    }

    .s-video-wrap:hover {
        transform: scale(1.02);
    }

    .popup-video:hover {
        transform: scale(1.15);
        box-shadow: 0 0 35px rgba(13,110,253,0.9);
    }
</style>

<section id="video" class="video-area p-relative">
    <div class="container">
        <div class="row">
            @foreach (var item in Model)
            {
                <div class="col-12">

                    <div class="s-video-wrap" style="background-image:url(@item.CoverImageUrl)">
                        
                        <div class="s-video-content">
                            
                            <h2>@item.Title</h2>
                            <p>Yapay zeka destekli sigorta çözümlerimizi keşfedin ve süreçlerinizi akıllı hale getirin.</p>

                            <a href="@item.VideoUrl" class="popup-video">
                                <i class="bi bi-play-fill"></i>
                            </a>
                           

                        </div>
                      

                    </div>

                </div>
            }
        </div>
    </div>
</section>