
@*
    _UILayoutFooterComponent
*@

<footer class="footer-bg footer-p pt-240" style="background-color: #28314b;">
    <div class="footer-top pb-70">
        <div class="container">
            <div class="row justify-content-between">

                <div class="col-xl-4 col-lg-4 col-sm-6">
                    <div class="footer-widget mb-30" data-aos="fade-up" data-aos-duration="1000">
                        <div class="f-widget-title">
                            <h2> <img src="~/insureyou/img/logo/f_logo.png" alt="img"></h2>
                        </div>
                        <div class="f-contact">
                            <p>@ViewBag.Info </p>

                        </div>
                        <div class="footer-social mt-10">
                            <a href="#"><i class="fab fa-facebook-f"></i></a>
                            <a href="#"><i class="fab fa-instagram"></i></a>
                            <a href="#"><i class="fab fa-twitter"></i></a>
                        </div>
                    </div>
                </div>
                <div class="col-xl-2 col-lg-2 col-sm-6">
                    <div class="footer-widget mb-30" data-aos="fade-up" data-aos-duration="1400">
                        <div class="f-widget-title">
                            <h2>Hızlı Linkler</h2>
                        </div>
                        <div class="footer-link">
                            <ul>
                                <li><a asp-controller="Home" asp-action="Index">Anasayfa</a></li>
                                <li><a href="about.html"> Hakkımızda</a></li>
                                <li><a href="services.html"> Hizmetlerimiz </a></li>
                                <li><a href="contact.html">Bize Yazın</a></li>
                                <li><a asp-controller="Blog" asp-action="Index">Blog</a></li>
                            </ul>
                        </div>
                    </div>
                </div>


                <div class="col-xl-3 col-lg-3 col-sm-6">
                    <div class="footer-widget mb-30" data-aos="fade-up" data-aos-duration="1600">
                        <div class="f-widget-title">
                            <h2>İletişim Bilgileri</h2>
                        </div>
                        <div class="f-contact">
                            <ul>
                                <li>
                                    <i class="icon fal fa-phone"></i>
                                    <span>@ViewBag.Phone </span>
                                </li>
                                <li>
                                    <i class="icon fal fa-envelope"></i>
                                    <span>
                                        <a href="mailto:info@example.com">@ViewBag.Email</a>
                                       
                                    </span>
                                </li>
                                <li>
                                    <i class="icon fal fa-map-marker-check"></i>
                                    <span>@ViewBag.Address</span>
                                </li>

                            </ul>

                        </div>

                    </div>
                </div>

                @await Component.InvokeAsync("_UILayoutFooterPostComponent")

            </div>
        </div>
    </div>
    <div class="copyright-wrap">
        <div class="container">
            <div class="row align-items-center">
                <div class="col-lg-12">
                    <div class="copy-text text-center">
                        © @DateTime.Now.Year InsureYou — Tüm hakları saklıdır. | Merve Arpacıoğlu Türk
                    </div>
                </div>
            </div>
        </div>
    </div>
</footer>