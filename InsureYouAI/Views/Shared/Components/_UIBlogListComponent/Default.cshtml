@model List<Article>
@*
   _UIBlogListComponent
*@


<div class="col-lg-8">

    @foreach(var item in Model)
    {
        <div class="bsingle__post mb-50">
            <div class="bsingle__post-thumb">
                <img src="@item.CoverImageUrl" alt="">
            </div>
            <div class="bsingle__content">
                <div class="meta-info">
                    <ul>
                        <li><i class="fal fa-user"></i>@item.AppUser.Name @item.AppUser.Surname</li>
                        <li><i class="fal fa-calendar-alt"></i> @item.CreatedDate.ToString("dd-MMM-yyyy")</li>
                        <li><i class="fal fa-folder-open"></i> @item.Category.CategoryName</li>
                        <li><i class="fal fa-comments"></i> @item.Comments.Count() Yorum</li>
                    </ul>
                </div>
                <h2>
                    <a href="blog-details.html">
                      @item.Title
                    </a>
                </h2>
                <p>@(item.Content.Length > 250
                    ? item.Content.Substring(0,250) +"..."
                    : item.Content)
                </p>
                <div class="blog__btn">
                    <a asp-controller="Blog" asp-action="Detail" asp-route-id="@item.ArticleId" class="btn">Devamını Oku</a>
                </div>
            </div>
        </div>
  


    }

    <div class="pagination-wrap mb-50">
        <nav>
            <ul class="pagination">
                <li class="page-item"><a href="#"><i class="fas fa-angle-double-left"></i></a></li>
                <li class="page-item active"><a href="#">1</a></li>
                <li class="page-item"><a href="#">2</a></li>
                <li class="page-item"><a href="#">3</a></li>
                <li class="page-item"><a href="#">...</a></li>
                <li class="page-item"><a href="#">10</a></li>
                <li class="page-item"><a href="#"><i class="fas fa-angle-double-right"></i></a></li>
            </ul>
        </nav>
    </div>
</div>