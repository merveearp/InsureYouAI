@model List<Plan>
@*
    _UIHomePricingAreaComponent
*@

<section id="pricing" class="pricing-area pt-70 pb-60 fix p-relative">
    <div class="container">


        @foreach (var item in Model)
        {
            <div class="row justify-content-center text-center mb-60">
                <div class="col-lg-8">

                    <div class="section-title-modern">
                        <span class="pricing-badge">Sigorta Planları</span>

                        <h2 class="pricing-title">
                            @item.Title
                        </h2>

                        <p class="pricing-desc">
                            @item.Description
                        </p>
                    </div>

                </div>
            </div>
        }


        <div class="row">
            @await Component.InvokeAsync("_UIHomePricingPlanComponent")
        </div>

    </div>
</section>