@model List<Article>
@*
    _UIHomeBlogComponent
*@
<style>


    .blog-card-link {
        text-decoration: none;
        color: inherit;
        display: block;
    }

        .blog-card-link:hover {
            transform: translateY(-5px);
            transition: 0.3s;
        }


    .blog-thumb2 {
        height: 220px; 
        overflow: hidden;
        border-radius: 10px 10px 0 0;
    }

        .blog-thumb2 img {
            width: 100%;
            height: 100%;
            object-fit: cover; 
            transition: 0.4s;
        }

    .blog-card-link:hover img {
        transform: scale(1.1);
    }
</style>


<section id="blog" class="blog-area p-relative fix pt-90 pb-90">
    <div class="container">
        <div class="row align-items-center mb-50">
            <div class="col-lg-6 col-md-6">
                <div class="section-title center-align " data-aos="fade-up" data-aos-duration="1000">
                    <h2>
                        Yeni Eklenen Makalelerimizi incelemek ister misiniz
                    </h2>

                </div>

            </div>
            <div class="col-lg-6 col-md-6 text-right  d-none d-lg-block">
                <a href="/Blog/Index" class="btn ss-btn" data-aos="fade-up" data-aos-duration="1000">Devamını Gör</a>
            </div>
        </div>
        <div class="row" data-aos="fade-up" data-aos-duration="1400">
            @foreach(var item in Model)
            {
                <div class="col-lg-4 col-md-6">
                    <a href="/Blog/Detail/@item.ArticleId" class="blog-card-link">

                        <div class="single-post2 hover-zoomin mb-30">

                            <div class="blog-thumb2">
                                <img src="@item.CoverImageUrl" alt="img">
                            </div>

                 
                            <div class="blog-content2">

                                <div class="b-meta">
                                    <ul>
                                        <li><i class="fal fa-user"></i> Admin</li>
                                        <li><i class="fal fa-automobile"></i> @item.Category.CategoryName</li>
                                        <li><i class="fal fa-calendar-alt"></i> @item.CreatedDate.ToString("dd MMM yyyy")</li>
                                    </ul>
                                </div>

                                <h4>@item.Title</h4>

                                <p>
                                    @(item.Content.Length > 100
                                        ? item.Content.Substring(0, 100) + "..."
                                        : item.Content)
                                </p>

                               
                                <div class="mt-3">
                                    <span class="btn btn-outline-primary btn-sm">
                                        Detay Gör →
                                    </span>
                                </div>

                            </div>

                        </div>

                    </a>
                </div>
            }
          
     

        </div>
    </div>
</section>