@model Message


<section id="contact" class="contact-area after-none contact-bg pb-120 p-relative fix">
    <div class="container">

        <div class="row align-items-center">
            <div class="col-lg-6">
                <div class="hero-img">
                    <img src="/images/contact.png" alt="img">
                </div>
            </div>
                <div class="col-lg-6 ">
                    <div class="section-title p-relative pr-60 mb-30">
                        <h2 data-aos="fade-up" data-aos-duration="1000">
                           Hemen Bize Mesajınızı Bırakın
                        </h2>
                      
                    </div>
                    <div class="tab-content" id="myTabContent" data-aos="fade-up" data-aos-duration="1600">
                        <div class="tab-pane fade show active" id="voverview" role="tabpanel">
                            <div class="contact-bg">
                            <form asp-action="SendMessage" asp-controller="Home" method="post" class="contact-form">
                                    <div class="row">
                                        <div class="col-lg-12">
                                            <div class="contact-field p-relative c-name mb-20">
                                                <input type="text" id="firstn" asp-for="NameSurname" placeholder="Adınız Soyadınız" required>
                                            </div>
                                        </div>

                                        <div class="col-lg-12">
                                            <div class="contact-field p-relative c-subject mb-20">
                                                <input type="email" id="email" asp-for="Email" placeholder="Email" required>
                                            </div>
                                        </div>
                                            <div class="col-lg-12">
                                                <div class="contact-field p-relative c-subject mb-20">
                                                    <input type="number"  asp-for="PhoneNumber" placeholder="Telefon Numaranız" required>
                                                    </div>
                                                </div>
                                      
                                        <div class="col-lg-12">
                                            <div class="contact-field p-relative c-name mb-20">
                                                <input type="text" id="des" asp-for="Subject" placeholder="Mesaj Konusu" required>
                                            </div>
                                        </div>

                                        <div class="col-lg-12">
                                            <div class="contact-field p-relative c-subject mb-20">
                                               <textarea class="form-control" rows="5" asp-for="MessageContent" placeholder="Mesajınızı Yazınız..."></textarea>
                                            </div>
                                        </div>
                                        <div class="col-lg-12">
                                            <div class="slider-btn mt-20">
                                                <button class="btn ss-btn" data-animation="fadeInRight" data-delay=".8s">Gönder</button>
                                            </div>
                                        </div>
                                    </div>
                                </form>
                            </div>
                        </div>
                      
                    </div>

                </div>
            </div>

        </div>

    </section>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    @{
        var successMessage = TempData["Success"] as string;
    }

    @if (successMessage != null)
    {
        <script>
            document.addEventListener("DOMContentLoaded", function () {
            Swal.fire({
            icon: 'success',
            title: 'Başarılı!',
            text: '@Html.Raw(successMessage)'
            });
            });
        </script>
    }