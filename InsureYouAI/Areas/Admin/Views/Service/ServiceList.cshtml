@model List<Service>

@{
    ViewData["Title"] = "Hizmet Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int count = 0;
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                🩺 Hizmet Listesi
            </h5>

            <a href="/Admin/Service/Create" class="btn btn-outline-primary">
                + Yeni Hizmet Ekle
            </a>
        </div>

        <div class="table-responsive">

            <table class="table table-striped table-hover align-middle">

                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>İkon</th>
                        <th>Görsel</th>
                        <th>Başlık</th>
                        <th>Açıklama</th>
                        <th style="width:180px">İşlemler</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        count++;

                        <tr>
                            <td>@count</td>

                            <td>
                                <i class="@item.IconUrl fs-4 text-primary"></i>
                            </td>

                            <td>
                                <img src="@item.ImageUrl"
                                     style="width:70px;height:50px;object-fit:cover;border-radius:6px" />
                            </td>

                            <td class="fw-semibold">
                                @item.Title
                            </td>

                            <td style="max-width:350px">
                                @(item.Description.Length > 80
                                                            ? item.Description.Substring(0, 80) + "..." 
                                                                    : item.Description)
                            </td>

                            <td>

                                <a href="/Admin/Service/Update/@item.ServiceId"
                                   class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <a href="/Admin/Service/Delete/@item.ServiceId"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
</div>