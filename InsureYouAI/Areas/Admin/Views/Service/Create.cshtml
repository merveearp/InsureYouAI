@model Service
@{
    ViewData["Title"] = "Yeni Hizmet Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                🛠️ Yeni Hizmet Girişi
            </h5>
        </div>

        <form method="post">

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Hizmet Başlığı
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-tag"></i>
                    </span>

                    <input type="text"
                           asp-for="Title"
                           class="form-control"
                           placeholder="Örn: Sağlık Sigortası"
                           required />
                </div>

                <small class="text-muted">
                    Hizmet başlığını açık şekilde giriniz.
                </small>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Icon Class
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-star"></i>
                    </span>

                    <input type="text"
                           asp-for="IconUrl"
                           class="form-control"
                           placeholder="Örn: bi bi-shield-check"
                           required />
                </div>

                <small class="text-muted">
                    Bootstrap icon class giriniz.
                </small>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Açıklama
                </label>

                <textarea asp-for="Description"
                          class="form-control"
                          rows="5"
                          placeholder="Hizmet açıklaması"></textarea>

                <small class="text-muted">
                    Hizmet hakkında kısa açıklama yazınız.
                </small>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Hizmet Görseli
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-image"></i>
                    </span>

                    <input type="text"
                           asp-for="ImageUrl"
                           id="imageUrlInput"
                           class="form-control"
                           placeholder="https://site.com/image.jpg"
                           required />
                </div>

                <div class="mt-3">
                    <img id="imagePreview"
                         src=""
                         class="shadow-sm border"
                         style="max-width:250px; display:none;" />
                </div>

                <small class="text-muted">
                    Hizmet görselini link olarak ekleyiniz.
                </small>
            </div>


            <div class="d-flex justify-content-start gap-2 mt-3">

                <a href="/Admin/Service/ServiceList"
                   class="btn btn-outline-danger">
                    Vazgeç
                </a>

                <button class="btn btn-outline-primary px-4">
                    Kaydet
                </button>

            </div>

        </form>

    </div>
</div>


<script>

    const imageInput = document.getElementById("imageUrlInput");
    const preview = document.getElementById("imagePreview");

    const defaultUrl = "/images/default-image.jpg";

    preview.src = defaultUrl;
    preview.style.display = "block";

    imageInput.addEventListener("input", function () {

        const url = this.value;

        if (url.length > 0) {
            preview.src = url;
        }
        else {
            preview.src = defaultUrl;
        }

    });

</script>