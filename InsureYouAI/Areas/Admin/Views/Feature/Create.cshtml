@model Feature

@{
    ViewData["Title"] = "Yeni Özellik Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="mb-3">
            <h5 class="fw-bold text-primary mb-0">
                ✨ Yeni Öne Çıkan Özellik Ekle
            </h5>
            <small class="text-muted">
                Ana sayfada gösterilecek öne çıkan alanı oluşturun.
            </small>
        </div>


        <form method="post">

            
            <div class="mb-3">
                <label class="form-label fw-semibold">Başlık</label>
                <input type="text" asp-for="Title" class="form-control" placeholder="Örn: Güvenilir Sigorta Danışmanlığı" />
                <span asp-validation-for="Title" class="text-danger"></span>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">Açıklama</label>
                <textarea asp-for="Description" class="form-control" rows="3"
                          placeholder="Örn: Risklerinizi analiz ederek size en uygun sigorta çözümlerini sunarız."></textarea>
                <span asp-validation-for="Description" class="text-danger"></span>
            </div>


            <div class="d-flex justify-content-end gap-2 mt-4">
                <a href="/Admin/Feature/FeatureList" class="btn btn-outline-secondary">
                    ← Geri Dön
                </a>

                <button type="submit" class="btn btn-primary">
                    💾 Kaydet
                </button>
            </div>

        </form>

    </div>
</div>