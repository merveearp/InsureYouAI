@model Testimonial
@{
    ViewData["Title"] = "Yeni Referans Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                💬 Yeni Referans Girişi
            </h5>
        </div>

        <form method="post">


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Ad Soyad
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-person"></i>
                    </span>

                    <input type="text"
                           asp-for="NameSurname"
                           class="form-control"
                           placeholder="Örn: Ahmet Yılmaz"
                           required />
                </div>

                <small class="text-muted">
                    Referans veren kişinin adını ve soyadını giriniz.
                </small>
            </div>



            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Ünvan
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-briefcase"></i>
                    </span>

                    <input type="text"
                           asp-for="Title"
                           class="form-control"
                           placeholder="Örn: Sigorta Danışmanı"
                           required />
                </div>

                <small class="text-muted">
                    Referans veren kişinin mesleğini veya ünvanını yazınız.
                </small>
            </div>


       
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Yorum
                </label>

                <textarea asp-for="CommentDetail"
                          class="form-control"
                          rows="5"
                          placeholder="Müşteri yorumunu giriniz"></textarea>

                <small class="text-muted">
                    Müşteri deneyimini anlatan yorumu giriniz.
                </small>
            </div>


           
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Referans Fotoğrafı
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-image"></i>
                    </span>

                    <input type="text"
                           asp-for="ImageUrl"
                           id="imageUrlInput"
                           class="form-control"
                           placeholder="https://site.com/photo.jpg"
                           required />
                </div>

                <div class="mt-3">
                    <img id="imagePreview"
                         src=""
                         class="shadow-sm border"
                         style="max-width:150px; border-radius:50%; display:none;" />
                </div>

                <small class="text-muted">
                    Referans fotoğrafını link olarak ekleyiniz.
                </small>
            </div>


            <div class="d-flex justify-content-start gap-2 mt-3">

                <a href="/Admin/Testimonial/TestimonialList"
                   class="btn btn-outline-danger">
                    Vazgeç
                </a>

                <button class="btn btn-outline-primary px-4">
                    Kaydet
                </button>

            </div>

        </form>

    </div>
</div>


<script>

    const imageInput = document.getElementById("imageUrlInput");
    const preview = document.getElementById("imagePreview");

    const defaultUrl = "/images/default-image.jpg";

    preview.src = defaultUrl;
    preview.style.display = "block";

    imageInput.addEventListener("input", function () {

        const url = this.value;

        if (url.length > 0) {
            preview.src = url;
        }
        else {
            preview.src = defaultUrl;
        }

    });

</script>