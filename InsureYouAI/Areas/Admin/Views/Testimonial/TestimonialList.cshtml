@model List<Testimonial>

@{
    ViewData["Title"] = "Referans Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int count = 0;
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                💬 Referans Listesi
            </h5>

            <a href="/Admin/Testimonial/Create" class="btn btn-outline-primary">
                + Yeni Referans Ekle
            </a>
        </div>

        <div class="table-responsive">

            <table class="table table-striped table-hover align-middle">

                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Fotoğraf</th>
                        <th>Ad Soyad</th>
                        <th>Unvan</th>
                        <th>Yorum</th>
                        <th style="width:180px">İşlemler</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in Model)
                    {
                        count++;

                        <tr>
                            <td>@count</td>

                            <td>
                                <img src="@item.ImageUrl"
                                     style="width:50px;height:50px;border-radius:50%;object-fit:cover;" />
                            </td>

                            <td class="fw-semibold">
                                @item.NameSurname
                            </td>

                            <td>
                                @item.Title
                            </td>

                            <td style="max-width:350px">

                                @(item.CommentDetail.Length > 80
                                                            ? item.CommentDetail.Substring(0, 80) + "..."
                                                            : item.CommentDetail)

                            </td>

                            <td>

                                <a href="/Admin/Testimonial/Update/@item.TestimonialId"
                                   class="btn btn-sm btn-outline-warning">
                                    <i class="bi bi-pencil-square"></i>
                                </a>

                                <a href="/Admin/Testimonial/Delete/@item.TestimonialId"
                                   class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-trash"></i>
                                </a>

                            </td>

                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
</div>