@model Article

@{
    ViewData["Title"] = "Yeni Blog Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                📝 Yeni Blog Yazısı
            </h5>
        </div>

        <form method="post">

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Blog Başlığı
                </label>

                <input type="text"
                       asp-for="Title"
                       class="form-control"
                       placeholder="Blog başlığı giriniz"
                       required />
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Kategori
                </label>

                <select asp-for="CategoryId"
                        asp-items="ViewBag.Categories"
                        class="form-control">
                    <option value="">Kategori seçiniz</option>
                </select>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Ana Kapak Görseli
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-image"></i>
                    </span>

                    <input type="text"
                           asp-for="MainCoverImageUrl"
                           id="mainImageInput"
                           class="form-control"
                           placeholder="https://site.com/image.jpg" />
                </div>

                <div class="mt-3">
                    <img id="mainImagePreview"
                         class="shadow-sm border rounded"
                         style="max-width:250px; display:none;" />
                </div>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Blog Detay Görseli
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-image"></i>
                    </span>

                    <input type="text"
                           asp-for="CoverImageUrl"
                           id="detailImageInput"
                           class="form-control"
                           placeholder="https://site.com/image.jpg" />
                </div>

                <div class="mt-3">
                    <img id="detailImagePreview"
                         class="shadow-sm border rounded"
                         style="max-width:250px; display:none;" />
                </div>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Blog İçeriği
                </label>

                <textarea asp-for="Content"
                          class="form-control"
                          rows="6"
                          placeholder="Blog içeriğini giriniz"></textarea>
            </div>


            <div class="d-flex gap-2 mt-3">

                <a href="/Admin/Article/Index"
                   class="btn btn-outline-danger">
                    Vazgeç
                </a>

                <button class="btn btn-outline-primary px-4">
                    Kaydet
                </button>

            </div>

        </form>

    </div>
</div>


<script>

    const mainInput = document.getElementById("mainImageInput");
    const mainPreview = document.getElementById("mainImagePreview");

    const detailInput = document.getElementById("detailImageInput");
    const detailPreview = document.getElementById("detailImagePreview");

    mainInput.addEventListener("input", function () {

        const url = this.value;

        if (url.length > 0) {
            mainPreview.src = url;
            mainPreview.style.display = "block";
        }
        else {
            mainPreview.style.display = "none";
        }

    });


    detailInput.addEventListener("input", function () {

        const url = this.value;

        if (url.length > 0) {
            detailPreview.src = url;
            detailPreview.style.display = "block";
        }
        else {
            detailPreview.style.display = "none";
        }

    });

</script>