@model List<Article>

@{
    ViewData["Title"] = "Blog Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int count = 0;
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                📂 Blog Listesi
            </h5>

            <a href="/Admin/Article/Create" class="btn btn-outline-primary">
                + Yeni Blog Ekle
            </a>
        </div>

        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Kapak</th>
                        <th>Başlık</th>
                        <th>Kategori</th>
                        <th>İçerik</th>
                        <th>Tarih</th>
                        <th style="width:220px">İşlemler</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            count++;

                            <tr>
                                <td>@count</td>

                                <td>
                                    <img src="@item.MainCoverImageUrl"
                                         style="width:80px;height:60px;object-fit:cover;border-radius:6px;" />
                                </td>

                                <td class="fw-semibold">
                                    @item.Title
                                </td>

                                <td>
                                    @item.Category?.CategoryName
                                </td>

                                <td>
                                    @(item.Content.Length > 80
                                                                ? item.Content.Substring(0, 80) + "..." 
                                                                                        : item.Content)
                                </td>

                                <td>
                                    @item.CreatedDate.ToString("dd.MM.yyyy")
                                </td>

                                <td>

                                    <a href="/Admin/Article/Update/@item.ArticleId"
                                       class="btn btn-sm btn-outline-success me-1">
                                        <i class="bi bi-pencil-square"></i>
                                    </a>

                                    <a href="/Admin/Article/Delete/@item.ArticleId"
                                       class="btn btn-sm btn-outline-danger me-1"
                                       onclick="return confirm('Bu blogu silmek istediğinize emin misiniz?')">
                                        <i class="bi bi-trash"></i>
                                    </a>

                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-info-circle fs-4"></i>
                                <p class="mt-2 mb-2">Henüz blog içeriği bulunmamaktadır.</p>

                                <a href="/Admin/Article/Create"
                                   class="btn btn-primary btn-sm">
                                    İlk Blogu Ekle
                                </a>
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>

    </div>
</div>