@model List<Article>

@{
    ViewData["Title"] = "Kategoriye Göre Makaleler";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int count = 0;
}

<style>

    .table tbody tr {
        border-bottom: 1px solid #f1f1f1;
    }

        .table tbody tr:hover {
            background-color: #f8fbff;
            transition: .2s ease;
        }

</style>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <div>
                <h5 class="mb-1 fw-bold text-primary">
                    🗂️ @ViewBag.CategoryName Kategorisine Ait Makaleler
                </h5>
                <p class="text-muted mb-0 small">
                    Bu sayfada yalnızca seçili kategoriye ait blog yazıları listelenir.
                </p>
            </div>

            <div class="d-flex gap-2">
                <a href="/Admin/Category/CategoryList"
                       class="btn btn-outline-secondary rounded-pill px-4">
                    <i class="bi bi-arrow-left"></i>
                    Kategorilere Dön
                </a>

              
            </div>

        </div>

        <div class="alert alert-primary border-0 rounded-4 d-flex align-items-center mb-4">
            <i class="bi bi-folder-fill fs-4 me-3"></i>
            <div>
                <strong>Kategori:</strong> @ViewBag.CategoryName
                <br />
                <span class="small">
                    Toplam @(Model != null ? Model.Count : 0) blog yazısı bulundu.
                </span>
            </div>
        </div>

        <div class="table-responsive">
            <table class="table table-hover align-middle table-borderless">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Kapak</th>
                        <th>Başlık</th>
                        <th>Kategori</th>
                        <th>Tarih</th>
                        <th style="width:220px">İşlemler</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            count++;

                            <tr>
                                <td>@count</td>

                                <td>
                                    <img src="@item.MainCoverImageUrl"
                                         style="width:140px;
                                    height:90px;
                                    object-fit:cover;
                                    border-radius:12px;
                                    box-shadow:0 4px 12px rgba(0,0,0,.08);" />
                                </td>

                                <td class="fw-semibold">
                                    @item.Title
                                </td>

                                <td>
                                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                                        @item.Category.CategoryName
                                    </span>
                                </td>

                                <td>
                                    @item.CreatedDate.ToString("dd.MM.yyyy")
                                </td>

                                <td>
                                    <a href="/Admin/Article/Update/@item.ArticleId"
                                           class="btn btn-sm btn-outline-success rounded-pill me-1">
                                        <i class="bi bi-pencil-square"></i>
                                        Güncelle
                                    </a>

                                    <a href="/Admin/Article/Delete/@item.ArticleId"
                                           class="btn btn-sm btn-outline-danger rounded-pill"
                                           onclick="return confirm('Bu blogu silmek istediğinize emin misiniz?')">
                                        <i class="bi bi-trash"></i>
                                        Sil
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                    else
                    {
                        <tr>
                            <td colspan="6" class="text-center text-muted py-5">
                                <i class="bi bi-folder-x fs-1 text-primary"></i>

                                <h6 class="mt-3 mb-2 fw-bold">
                                    Bu kategoriye ait blog bulunamadı.
                                </h6>

                                <p class="mb-3">
                                    Bu kategori için henüz herhangi bir makale eklenmemiş.
                                </p>

                                <a href="/Admin/Category/CategoryList"
                                       class="btn btn-outline-secondary rounded-pill px-4 me-2">
                                    <i class="bi bi-arrow-left"></i>
                                    Kategorilere Dön
                                </a>

                                <a href="/Admin/Article/Create"
                                       class="btn btn-primary rounded-pill px-4">
                                    İlk Blogu Ekle
                                </a>
                            </td>
                        </tr>
                    }

                </tbody>
            </table>
        </div>

    </div>
</div>