@model List<Category>

@{
    ViewData["Title"] = "Kategori Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int count = 0;
}

<style>

    .category-card {
        transition: all .3s ease;
        cursor: pointer;
    }

        .category-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,.08) !important;
        }
</style>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="mb-0 fw-bold text-primary">
                📂 Kategori Listesi
            </h5>

            <a href="/Admin/Category/Create"
                   class="btn btn-outline-primary rounded-pill px-4">
                + Yeni Kategori
            </a>
        </div>

        <div class="row">

            @foreach (var item in Model)
            {
                count++;

                <div class="col-md-6 col-lg-4 mb-4">

                    <div class="card border-0 shadow-sm rounded-4 h-100 category-card">

                        <a href="/Admin/Category/CategoryByArticleList/@item.CategoryId"
                               class="text-decoration-none text-dark flex-grow-1">

                            <div class="card-body d-flex flex-column">

                                <div class="d-flex align-items-center justify-content-between mb-3">

                                    <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                                        #@count
                                    </span>

                                    <div class="fs-3 text-primary">
                                        <i class="bi bi-folder-fill"></i>
                                    </div>

                                </div>

                                <h5 class="fw-bold mb-3">
                                    @item.CategoryName
                                </h5>

                                <p class="text-muted small mb-0">
                                    Bu kategoriye ait blogları görüntüle
                                </p>

                            </div>

                        </a>

                        <div class="card-footer bg-transparent border-0 pt-0">
                            <div class="d-flex gap-2">

                                <a href="/Admin/Category/Update/@item.CategoryId"
                                       class="btn btn-outline-success w-100 rounded-pill">
                                    <i class="bi bi-pencil-square"></i>
                                    Güncelle
                                </a>

                                <a href="/Admin/Category/Delete/@item.CategoryId"
                                       class="btn btn-outline-danger w-100 rounded-pill"
                                       onclick="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?')">

                                    <i class="bi bi-trash"></i>
                                    Sil
                                </a>

                            </div>
                        </div>

                    </div>
                </div>
            }

        </div>

    </div>
</div>

<style>

    .category-card {
        transition: all .3s ease;
    }

        .category-card:hover {
            transform: translateY(-6px);
            box-shadow: 0 12px 30px rgba(0,0,0,.08) !important;
        }

</style>