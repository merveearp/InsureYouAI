
@model List<Category>

@{
    ViewData["Title"] = "Kategori Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int count = 0;
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

       
        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                📂 Kategori Listesi
            </h5>

            <a href="/Admin/Category/Create" class="btn btn-outline-primary">
                + Yeni Kategori
            </a>
        </div>

      
       
        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Kategori Adı</th>
                        <th style="width:200px">İşlemler</th>


                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td>@count</td>
                            <td class="fw-semibold">@item.CategoryName</td>
                            <td>
                                <a href="/Admin/Category/Update/@item.CategoryId"
                                   class="btn btn-sm btn-outline-success me-2">
                                    <i class="bi bi-pencil-square"></i> Güncelle
                                </a>

                                <a href="/Admin/Category/Delete/@item.CategoryId"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Bu kategoriyi silmek istediğinize emin misiniz?')">
                                    <i class="bi bi-trash"></i> Sil
                                </a>
                                <a href="/"
                                   class="btn btn-sm btn-outline-dark me-2">
                                    <i class="bi bi-eye-fill"></i> Sitede Gör
                                </a>
                            </td>
                           
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>

