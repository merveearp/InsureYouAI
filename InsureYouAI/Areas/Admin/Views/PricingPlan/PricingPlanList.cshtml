@model List<PricingPlan>
@{
    ViewData["Title"] = "Sigorta Plan Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int count = 0;
}


<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">


        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                📂 Plan Listesi
            </h5>

            <a href="/Admin/AboutItem/Create" class="btn btn-outline-primary">
                + Yeni Sigorta Planı Ekle
            </a>
        </div>



        <div class="table-responsive">
            <table class="table table-striped table-hover align-middle">
                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Plan İçeriği</th>
                        <th>Plan Açıklaması </th>
                        <th>Fiyatlandırma </th>
                        <th>Anasayfa Durumu </th>
                        <th style="width:200px">İşlemler</th>


                    </tr>
                </thead>
                <tbody>
                    @if(Model != null && Model.Any())
                    {
                    @foreach (var item in Model)
                    {
                        count++;
                        <tr>
                            <td>@count</td>
                            <td class="fw-semibold">@item.Title</td>
                            <td class="fw-semibold">@item.Description</td>
                            <td class="fw-semibold">@item.Price</td>
                           
                                @if (item.IsFeature== true)
                                {
                                <td class="fw-semibold">Aktif</td>
                                }else
                                {
                                <td class="fw-semibold">Pasif </td>
                                }
                           
                            <td>
                                <a href="/Admin/PricingPlan/Update/@item.PricingPlanId"
                                   class="btn btn-sm btn-outline-success me-2">
                                    <i class="bi bi-pencil-square"></i> Güncelle
                                </a>

                                <a href="/Admin/PricingPlan/Delete/@item.PricingPlanId"
                                   class="btn btn-sm btn-outline-danger"
                                   onclick="return confirm('Bu pricingplan silmek istediğinize emin misiniz?')">
                                    <i class="bi bi-trash"></i> Sil
                                </a>
                               
                            </td>

                        </tr>
                        }
                    }else
                    {

                        <tr>
                            <td colspan="7" class="text-center text-muted py-4">
                                <i class="bi bi-info-circle fs-4"></i>
                                <p class="mt-2 mb-2">Henüz sigorta paket içeriği bulunmamaktadır.</p>

                                <a href="/Admin/Article/Create"
                                   class="btn btn-primary btn-sm">
                                    İlk paketi Ekle
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

    </div>
</div>



