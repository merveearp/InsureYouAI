@model PricingPlan
@{
    ViewData["Title"] = "GetPlan";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="mb-0 fw-bold text-warning">
                ✏️ Sigorta Planı Güncelle
            </h5>
        </div>

        <form method="post" asp-action="Update" asp-controller="PricingPlan">

            <input type="hidden" asp-for="PricingPlanId" />


            <div class="mb-3">
                <label class="form-label fw-semibold">Plan Başlığı</label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-card-heading"></i>
                    </span>

                    <input type="text"
                           asp-for="Title"
                           class="form-control"
                           required />
                </div>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">Plan Fiyatı</label>

                <div class="input-group">
                    <span class="input-group-text bg-light">₺</span>

                    <input type="number"
                           asp-for="Price"
                           class="form-control"
                           required />
                </div>
            </div>


            <div class="mb-4">
                <label class="form-label fw-semibold">Anasayfada Göster</label>

                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           asp-for="IsFeature" />

                    <label class="form-check-label">
                        Bu plan anasayfa fiyat paketlerinde görünsün
                    </label>
                </div>
            </div>

            <div class="d-flex justify-content-start gap-2">
                <a href="/Admin/PricingPlan/PricingPlanList"
                       class="btn btn-outline-danger">
                    Geri Dön
                </a>

                <button class="btn btn-warning px-4">
                    <i class="bi bi-pencil-square"></i> Güncelle
                </button>
            </div>

        </form>


        <div class="mt-5">
            <h6 class="fw-bold text-primary mb-3">
                📋 Plan Özellikleri
            </h6>

            <form method="post" asp-action="CreateItem" asp-controller="PricingPlan" class="mb-3">
                <input type="hidden" name="PricingPlanId" value="@Model.PricingPlanId" />

                <div class="input-group">
                    <input type="text"
                           name="Title"
                           class="form-control"
                           placeholder="Yeni özellik ekle..."
                           required />

                    <button class="btn btn-primary">
                        + Ekle
                    </button>
                </div>
            </form>

            @if (Model.PricingPlanItems != null && Model.PricingPlanItems.Any())
            {
                <table class="table table-striped table-hover align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Özellik</th>
                            <th style="width:150px">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            int count = 0;
                        }
                        @foreach (var item in Model.PricingPlanItems)
                        {
                            count++;
                            <tr>
                                <td>@count</td>
                                <td>@item.Title</td>
                                <td>

                                    <div class="d-flex justify-content-end gap-2">

                                 
                                        <button type="button"
                                                class="btn btn-sm btn-success"
                                                data-bs-toggle="modal"
                                                data-bs-target="#updateModal_@item.PricingPlanItemId">
                                            <i class="bi bi-pencil"></i>
                                        </button>


                                        <form method="post"
                                              asp-action="DeleteItem"
                                              asp-controller="PricingPlan"
                                              onsubmit="return confirm('Silmek istediğinize emin misiniz?')">

                                            <input type="hidden" name="id" value="@item.PricingPlanItemId" />

                                            <button type="submit"
                                                    class="btn btn-sm btn-outline-danger">
                                                🗑
                                            </button>
                                        </form>

                                    </div>

                      
                                    <div class="modal fade" id="updateModal_@item.PricingPlanItemId" tabindex="-1">
                                        <div class="modal-dialog">
                                            <div class="modal-content">

                                                <form method="post" asp-action="UpdateItem">

                                                    <div class="modal-header">
                                                        <h5 class="modal-title">Özellik Güncelle</h5>
                                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                                    </div>

                                                    <div class="modal-body">

                                                        <input type="hidden" name="PricingPlanItemId" value="@item.PricingPlanItemId" />
                                                        <input type="hidden" name="PricingPlanId" value="@Model.PricingPlanId" />

                                                        <label class="form-label">Özellik</label>
                                                        <input type="text"
                                                               name="Title"
                                                               value="@item.Title"
                                                               class="form-control" />

                                                    </div>

                                                    <div class="modal-footer">
                                                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">
                                                            Kapat
                                                        </button>

                                                        <button type="submit" class="btn btn-success">
                                                            Güncelle
                                                        </button>
                                                    </div>

                                                </form>

                                            </div>
                                        </div>
                                    </div>

                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            }
            else
            {
                <div class="alert alert-warning">
                    ⚠️ Bu plana ait özellik bulunamadı.
                </div>
            }
        </div>

    </div>
</div>

