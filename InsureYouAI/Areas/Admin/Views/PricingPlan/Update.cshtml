@model PricingPlan
@{
    ViewData["Title"] = "Plan Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="mb-0 fw-bold text-warning">
                ✏️ Sigorta Planı Güncelle
            </h5>
        </div>

        <form method="post">

            <input type="hidden" asp-for="PricingPlanId" />

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Plan Başlığı
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-card-heading"></i>
                    </span>

                    <input type="text"
                           asp-for="Title"
                           class="form-control"
                           required />
                </div>

                <small class="text-muted">
                    Sigorta planının başlık bilgisini düzenleyiniz.
                </small>
            </div>

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Plan Fiyatı
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        ₺
                    </span>

                    <input type="number"
                           asp-for="Price"
                           class="form-control"
                           required />
                </div>

                <small class="text-muted">
                    Sigorta planının fiyat bilgisini düzenleyiniz.
                </small>
            </div>


         
            <div class="mb-4">
                <label class="form-label fw-semibold">
                    Anasayfada Göster
                </label>

                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           asp-for="IsFeature" />

                    <label class="form-check-label">
                        Bu plan anasayfa fiyat paketlerinde görünsün
                    </label>
                </div>

                <small class="text-muted">
                    Seçili olursa plan anasayfada gösterilir.
                </small>
            </div>


           
            <div class="d-flex justify-content-start gap-2">

                <a href="/Admin/PricingPlan/PlanPricingList"
                   class="btn btn-outline-danger">
                    Vazgeç
                </a>

                <button class="btn btn-warning px-4">
                    <i class="bi bi-pencil-square"></i> Güncelle
                </button>

            </div>

        </form>

    </div>
</div>