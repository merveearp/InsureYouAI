@model PricingPlan
@{
    ViewData["Title"] = "Sigorta Planı Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="mb-0 fw-bold text-primary">
                📂 Yeni Sigorta Planı Ekle
            </h5>
        </div>

        <form method="post">

           
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Plan Başlığı
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-card-heading"></i>
                    </span>

                    <input type="text"
                           asp-for="Title"
                           class="form-control"
                           placeholder="Örn: Premium Sağlık Sigortası"
                           required />
                </div>

                <small class="text-muted">
                    Sigorta planının başlık bilgisini giriniz.
                </small>
            </div>


           
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Plan Açıklaması
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-chat-left-text"></i>
                    </span>

                    <input type="text"
                           asp-for="Description"
                           class="form-control"
                           placeholder="Örn: Yatarak ve ayakta tedavi teminatı içerir."
                           required />
                </div>

                <small class="text-muted">
                    Planın içeriğini kısa şekilde açıklayınız.
                </small>
            </div>


         
            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Plan Fiyatı
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        ₺
                    </span>

                    <input type="number"
                           asp-for="Price"
                           class="form-control"
                           placeholder="Örn: 1500"
                           required />
                </div>

                <small class="text-muted">
                    Sigorta planının aylık veya yıllık ücretini giriniz.
                </small>
            </div>


           
            <div class="mb-4">
                <label class="form-label fw-semibold">
                    Anasayfada Göster
                </label>

                <div class="form-check">
                    <input class="form-check-input"
                           type="checkbox"
                           asp-for="IsFeature" />

                    <label class="form-check-label">
                        Bu plan anasayfa fiyat paketleri bölümünde görünsün
                    </label>
                </div>

                <small class="text-muted">
                    Seçili olursa plan anasayfada kullanıcıya gösterilir.
                </small>
            </div>


           
            <div class="d-flex justify-content-start gap-2">

                <a href="/Admin/PricingPlan/PlanPricingList"
                   class="btn btn-outline-danger">
                    Vazgeç
                </a>

                <button class="btn btn-primary px-4">
                    <i class="bi bi-save"></i> Kaydet
                </button>

            </div>

        </form>

    </div>
</div>