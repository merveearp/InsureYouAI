@model Message

@{
    ViewData["Title"] = "Mesaj Detayı";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">

    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">

            <h5 class="fw-bold text-primary">
                📩 Mesaj Detayı
            </h5>

            <a href="/Admin/Message/MessageList"
               class="btn btn-outline-secondary btn-sm">
                <i class="bi bi-arrow-left"></i> Listeye Dön
            </a>

        </div>


        <div class="row mb-3">

            <div class="col-md-6">

                <p>
                    <strong>
                        <i class="bi bi-person"></i> Gönderen
                    </strong>
                    <br />
                    @Model.NameSurname
                </p>

            </div>


            <div class="col-md-6">

                <p>
                    <strong>
                        <i class="bi bi-envelope"></i> Email
                    </strong>
                    <br />
                    @Model.Email
                </p>

            </div>

        </div>


        <div class="row mb-3">

            <div class="col-md-6">

                <p>
                    <strong>
                        <i class="bi bi-telephone"></i> Telefon
                    </strong>
                    <br />
                    @Model.PhoneNumber
                </p>

            </div>


            <div class="col-md-6">

                <p>
                    <strong>
                        <i class="bi bi-calendar"></i> Gönderim Tarihi
                    </strong>
                    <br />
                    @Model.SendDate.ToString("dd.MM.yyyy HH:mm")
                </p>

            </div>

        </div>


        <div class="mb-3">

            <label class="fw-bold mb-2">
                <i class="bi bi-chat-left-text"></i> Konu
            </label>

            <div class="border rounded p-3 bg-light">
                @Model.Subject
            </div>

        </div>


        <div class="mb-4">

            <label class="fw-bold mb-2">
                <i class="bi bi-chat-dots"></i> Mesaj İçeriği
            </label>

            <div class="border rounded p-3 bg-light">
                @Model.MessageContent
            </div>

        </div>


        <div class="d-flex gap-2">

            @if (!Model.IsRead)
            {
                <a href="/Admin/Message/ChangeStatus/@Model.MessageId"
                   class="btn btn-sm btn-success me-1">
                    <i class="bi bi-envelope-open"></i>
                </a>
            }
            else
            {
                <a href="/Admin/Message/ChangeStatus/@Model.MessageId"
                   class="btn btn-sm btn-outline-warning me-1">
                    <i class="bi bi-envelope"></i>
                </a>
            }
            <a href="/Admin/Message/Delete/@Model.MessageId"
               class="btn btn-outline-danger"
               onclick="return confirm('Bu mesajı silmek istediğinize emin misiniz?')">
                <i class="bi bi-trash"></i> Sil
            </a>

            <a href="/Admin/Message/MessageList"
               class="btn btn-outline-dark">
                Listeye Dön
            </a>

        </div>

    </div>

</div>