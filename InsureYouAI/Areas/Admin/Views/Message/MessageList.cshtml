@model List<Message>

@{
    ViewData["Title"] = "Mesaj Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int count = 0;
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">

            <h5 class="mb-0 fw-bold text-primary">
                📩 Gelen Mesajlar
            </h5>

            <div>

                <a href="/Admin/Message/MessageList"
                   class="btn btn-sm btn-outline-dark me-1">
                    <i class="bi bi-list"></i> Tümü
                </a>

                <a href="/Admin/Message/UnReadList"
                   class="btn btn-sm btn-outline-warning me-1">
                    <i class="bi bi-envelope"></i> Okunmamış @ViewBag.UnReadMessage
                </a>

                <a href="/Admin/Message/IsReadList"
                   class="btn btn-sm btn-outline-success">
                    <i class="bi bi-envelope-open"></i> Okunan @ViewBag.ReadMessage
                </a>

            </div>

        </div>

        <div class="table-responsive">

            <table class="table table-striped table-hover align-middle">

                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Gönderen</th>
                        <th>Email</th>
                        <th>Telefon</th>
                        <th>Konu</th>
                        <th>İçerik</th>
                        <th>Tarih</th>
                        <th>Durum</th>
                        <th style="width:200px">İşlemler</th>
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            count++;

                            <tr>

                                <td>@count</td>

                                <td class="fw-semibold">
                                    @item.NameSurname
                                </td>

                                <td>
                                    <i class="bi bi-envelope text-primary me-1"></i>
                                    @item.Email
                                </td>

                                <td>
                                    <i class="bi bi-telephone text-primary me-1"></i>
                                    @item.PhoneNumber
                                </td>

                                <td>
                                    @item.Subject
                                </td>

                                <td>
                                    @(string.IsNullOrEmpty(item.MessageContent)
                                                                ? "-"
                                                                : item.MessageContent.Length > 80
                                                                ? item.MessageContent.Substring(0, 80) + "..."
                                                                : item.MessageContent)
                                </td>

                                <td>
                                    @item.SendDate.ToString("dd.MM.yyyy HH:mm")
                                </td>

                                <td>

                                    @if (item.IsRead)
                                    {
                                        <span class="badge bg-success">
                                            Okundu
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">
                                            Yeni Mesaj
                                        </span>
                                    }

                                </td>

                                <td>

                                    <a href="/Admin/Message/Detail/@item.MessageId"
                                       class="btn btn-sm btn-outline-dark me-1">
                                        <i class="bi bi-eye"></i>
                                    </a>

                                    @if (!item.IsRead)
                                    {
                                        <a href="/Admin/Message/ChangeStatus/@item.MessageId"
                                           class="btn btn-sm btn-success me-1">
                                            <i class="bi bi-envelope-open"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <a href="/Admin/Message/ChangeStatus/@item.MessageId"
                                           class="btn btn-sm btn-outline-warning me-1">
                                            <i class="bi bi-envelope"></i>
                                        </a>
                                    }

                                    <a href="/Admin/Message/Delete/@item.MessageId"
                                       class="btn btn-sm btn-outline-danger"
                                       onclick="return confirm('Bu mesajı silmek istediğinize emin misiniz?')">
                                        <i class="bi bi-trash"></i>
                                    </a>

                                </td>

                            </tr>
                        }
                    }

                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">

                                <i class="bi bi-info-circle fs-4"></i>

                                <p class="mt-2">
                                    Henüz mesaj bulunmamaktadır.
                                </p>

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
</div>