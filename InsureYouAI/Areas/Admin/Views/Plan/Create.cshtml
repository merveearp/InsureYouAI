@model Plan
@{
    ViewData["Title"] = "Plan İçeriği Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}


<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                📂 Yeni Plan Yazı Girişi
            </h5>
        </div>

        <form method="post">

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Başlık
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-tag"></i>
                    </span>
                    <input type="text"
                           asp-for="Title"
                           class="form-control"
                           placeholder="Hakkımda Başlığı"
                           required />
                </div>

                <small class="text-muted">
                    Plan başlığını açık ve anlaşılır şekilde giriniz.
                </small>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Açıklama
                </label>

                <textarea asp-for="Description"
                          class="form-control"
                          rows="5"
                          placeholder="Plan açıklaması"></textarea>

                <small class="text-muted">
                    Hakkımızda açıklamasını detaylı şekilde giriniz.
                </small>
            </div>

            <div class="d-flex justify-content-start gap-2 mt-3">

                <a href="/Admin/Plan/PlanList"
                   class="btn btn-outline-danger">
                    Vazgeç
                </a>

                <button class="btn btn-outline-primary px-4">
                    Kaydet
                </button>

            </div>

        </form>

    </div>
</div>

