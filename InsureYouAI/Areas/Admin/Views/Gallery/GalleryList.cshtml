@model List<Gallery>
@{
    ViewData["Title"] = "Fotograf Albümü";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}
<style>

    .gallery-item {
        transition: 0.3s;
    }

        .gallery-item:hover {
            background: #f8f9fa;
            transform: translateY(-3px);
        }
</style>
<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">


        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="mb-0 fw-bold text-primary">
                📂 Galeri
            </h5>

            <a href="/Admin/Gallery/Create" class="btn btn-outline-primary">
                + Yeni Fotoğraf Ekle
            </a>
        </div>


        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="gallery-item mb-4 p-3 rounded shadow-sm border">

                    <div class="row align-items-center">

  
                        <div class="col-md-3">
                            <img src="@item.ImageUrl"
                                 class="img-fluid rounded"
                                 style="height:150px; width:100%; object-fit:cover;" />
                        </div>

                        <div class="col-md-6">
                            <h5 class="fw-bold mb-2">@item.Title</h5>
                        </div>


                        <div class="col-md-3 text-end">

                            <a href="/Admin/Gallery/Update/@item.GalleryId"
                               class="btn btn-outline-success btn-sm me-2">
                                <i class="bi bi-pencil-square"></i>
                            </a>

                            <a href="/Admin/Gallery/Delete/@item.GalleryId"
                               class="btn btn-outline-danger btn-sm"
                               onclick="return confirm('Silmek istediğinize emin misiniz?')">
                                <i class="bi bi-trash"></i>
                            </a>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="text-center text-muted py-5">
                <i class="bi bi-info-circle fs-3"></i>

                <p class="mt-3">
                    Henüz galeri içeriği bulunmamaktadır.
                </p>

                <a href="/Admin/Gallery/Create"
                   class="btn btn-primary btn-sm mt-2">
                    İlk İçeriği Ekle
                </a>
            </div>
        }

    </div>
</div>