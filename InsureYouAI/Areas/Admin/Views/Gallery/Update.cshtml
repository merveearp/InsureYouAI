@model Gallery
@{
    ViewData["Title"] = "Update";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}


<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                📂 Galeri Görsel Girişi
            </h5>
        </div>

        <form method="post">
            <input type="hidden" asp-for="GalleryId" />

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Başlık
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-tag"></i>
                    </span>
                    <input type="text"
                           asp-for="Title"
                           class="form-control"
                           placeholder="Görsel Başlığı"
                           required />
                </div>

                <small class="text-muted">
                    Görsel başlığını açık ve anlaşılır şekilde giriniz.
                </small>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Galeri Görsel
                </label>
                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-image"></i>
                    </span>

                    <input type="text"
                           asp-for="ImageUrl"
                           id="imageUrlInput"
                           class="form-control"
                           placeholder="https://site.com/image.jpg"
                           required />
                </div>

                <div class="mt-3">
                    <img id="imagePreview"
                         src=""
                         class="shadow-sm border"
                         style="max-width:250px; display:none;" />
                </div>

                <small class="text-muted">
                    Galeri görselini link olarak ekleyiniz.
                </small>
            </div>

            <div class="d-flex justify-content-start gap-2 mt-3">

                <a href="/Admin/Gallery/GalleryList"
                       class="btn btn-outline-danger">
                    Vazgeç
                </a>

                <button class="btn btn-outline-primary px-4">
                    Kaydet
                </button>

            </div>

        </form>

    </div>
</div>

<script>

    const imageInput = document.getElementById("imageUrlInput");
    const preview = document.getElementById("imagePreview");

    const defaultUrl = "/images/default-image.jpg";

    preview.src = defaultUrl;
    preview.style.display = "block";

    imageInput.addEventListener("input", function () {

        let url = this.value.trim();

        if (url && !url.startsWith("http") && !url.startsWith("/")) {
            url = "/" + url;
        }

        if (url.length > 0) {
            preview.src = url;
        } else {
            preview.src = defaultUrl;
        }

    });


    preview.onerror = function () {
        preview.src = defaultUrl;
    };

</script>
