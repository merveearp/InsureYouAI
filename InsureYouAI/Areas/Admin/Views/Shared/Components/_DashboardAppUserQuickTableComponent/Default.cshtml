@using InsureYouAI.Areas.Admin.Models
@model List<UserQuickTableModel>

<div class="col-12 col-lg-6 col-xl-6 d-flex">

    <div class="card rounded-4 w-100 border-0 shadow-sm">
        <div class="card-body">

            <div class="d-flex align-items-center justify-content-between mb-4">
                <div>
                    <h6 class="mb-1 fw-bold">
                        En Popüler Kullanıcılar ve Müşteriler
                    </h6>

                    <p class="text-muted mb-0 small">
                        Poliçe sayısına göre en aktif müşteriler
                    </p>
                </div>

                <div class="fs-4 text-warning">
                    <i class="bi bi-trophy-fill"></i>
                </div>
            </div>

            <div class="user-quick-list">

                @foreach (var item in Model)
                {
                    <div class="user-quick-item d-flex align-items-center justify-content-between">

                        <div class="d-flex align-items-center gap-3">

                            <img src="@item.ImageUrl"
                                 class="user-avatar"
                                 onerror="this.src='/images/default-user.png'"
                                 alt="user image" />

                            <div>

                                <h6 class="mb-1 fw-semibold user-name">
                                    @item.FullName
                                </h6>

                                <div class="d-flex align-items-center gap-2">

                                    <span class="policy-badge">
                                        <i class="bi bi-shield-check me-1"></i>
                                        @item.PolicyCount poliçe
                                    </span>

                                </div>

                            </div>

                        </div>

                        <div class="premium-area text-end">

                            <div class="premium-price">
                                @item.TotalPremiumAmount.ToString("N0") ₺
                            </div>

                            <small class="text-muted">
                                Toplam Prim
                            </small>

                        </div>

                    </div>
                }

            </div>

        </div>
    </div>

</div>

<style>

    .user-quick-list {
        max-height: 420px;
        overflow-y: auto;
        overflow-x: hidden;
        padding-right: 8px;
    }

    .user-quick-item {
        padding: 14px 8px;
        border-bottom: 1px solid #f1f3f5;
        transition: all .25s ease;
    }

        .user-quick-item:hover {
            background: #f8fafc;
            border-radius: 16px;
            transform: translateX(4px);
        }

    .user-avatar {
        width: 50px;
        height: 50px;
        border-radius: 50%;
        object-fit: cover;
        border: 2px solid #eef2ff;
    }

    .user-name {
        color: #344050;
        font-size: 15px;
    }

    .policy-badge {
        padding: 5px 10px;
        border-radius: 999px;
        background: #eef7ff;
        color: #2563eb;
        font-size: 12px;
        font-weight: 600;
        white-space: nowrap;
    }

    .premium-area {
        min-width: 120px;
    }

    .premium-price {
        font-size: 16px;
        font-weight: 700;
        color: #1f2937;
    }

    .user-quick-list::-webkit-scrollbar {
        width: 6px;
    }

    .user-quick-list::-webkit-scrollbar-track {
        background: #f1f1f1;
        border-radius: 20px;
    }

    .user-quick-list::-webkit-scrollbar-thumb {
        background: #facc15;
        border-radius: 20px;
    }

</style>