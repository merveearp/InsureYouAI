@* _DashboardSubCharts1Component *@
@{
    var policyData = ViewBag.policyData;
}

<style>

    .policy-small-card {
        min-height: 245px;
    }
</style>
<div class="col">
    <div class="card rounded-4 h-100 policy-small-card">
        <div class="card-body d-flex flex-column">
            <div class="d-flex align-items-center justify-content-between mb-3">
                <div>
                    <h6 class="mb-0 fw-semibold">Poliçe Sayısı</h6>
                    <p class="mb-0 small text-muted">Poliçe türlerine göre dağılım</p>
                </div>
                <div class="fs-2 text-primary">
                    <i class="bi bi-shield-check"></i>
                </div>
            </div>

            <div id="policychart1" class="mt-auto"></div>
        </div>
    </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<script>
    var policyData = @Html.Raw(policyData);

    var policyTypes = policyData.map(x => x.PolicyType);
    var policyCounts = policyData.map(x => x.Count);

    var options = {
        series: [{
            name: "Poliçe Sayısı",
            data: policyCounts
        }],
        chart: {
            type: "area",
            height: 120,
            sparkline: {
                enabled: true
            },
            toolbar: {
                show: false
            }
        },
        stroke: {
            curve: "smooth",
            width: 2
        },
        fill: {
            opacity: 0.25
        },
        xaxis: {
            categories: policyTypes
        },
        tooltip: {
            x: {
                formatter: function (value, opts) {
                    return policyTypes[opts.dataPointIndex];
                }
            },
            y: {
                formatter: function (value) {
                    return value + " poliçe";
                }
            }
        }
    };

    var chart = new ApexCharts(document.querySelector("#policychart1"), options);
    chart.render();
</script>