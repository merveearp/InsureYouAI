@using InsureYouAI.Areas.Admin.Models
@using System.Globalization
@model List<PolicyTypeModel>

@*
   _DashboardPiePolicyTypeComponent
*@

@{
    var labels = Model.Select(x => x.PolicyType).ToList();
    var counts = Model.Select(x => x.Count).ToList();
}

<div class="col-12 col-lg-6 col-xl-6 d-flex">

    <div class="card rounded-4 w-100">

        <div class="card-header bg-transparent border-0 pt-4 px-4">

            <div class="d-flex align-items-center justify-content-between">

                <div>
                    <h5 class="mb-1 fw-bold">
                        Poliçe Tür Analizi
                    </h5>

                    <p class="text-muted mb-0 small">
                        Poliçe kategorilerine göre dağılım grafiği
                    </p>
                </div>

                <div class="fs-2 text-primary">
                    <i class="bi bi-pie-chart-fill"></i>
                </div>

            </div>

        </div>

        <div class="card-body">

            <div id="policyTypePieChart"></div>


        </div>

    </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/apexcharts"></script>

<script>
var options = {

    series: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(counts)),

    chart: {
        type: 'donut',
        height: 520
    },

    labels: @Html.Raw(System.Text.Json.JsonSerializer.Serialize(labels)),

    plotOptions: {
        pie: {
            donut: {
                size: '68%'
            }
        }
    },

    legend: {
        position: 'bottom',
        fontSize: '15px',
        itemMargin: {
            horizontal: 12,
            vertical: 8
        }
    },

    dataLabels: {
        enabled: true
    },

    colors: [
        '#6366f1',
        '#22c55e',
        '#f59e0b',
        '#ef4444',
        '#0ea5e9',
        '#8b5cf6',
        '#14b8a6',
        '#f97316',
        '#ec4899'
    ]
};

    var chart = new ApexCharts(
        document.querySelector("#policyTypePieChart"),
        options
    );

    chart.render();

</script>

<style>

    .policy-emoji-box {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        background: #f4f7ff;
        border: 1px solid #e9edf5;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 20px;
    }

</style>