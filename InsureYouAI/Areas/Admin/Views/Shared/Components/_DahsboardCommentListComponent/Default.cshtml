@model List<Comment>
@* _DahsboardCommentListComponent *@


<style>
    .review-card {
        transition: all .25s ease;
    }

        .review-card:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 22px rgba(0,0,0,.08);
            background-color: #fff !important;
        }

    .review-list {
        max-height: 420px;
        overflow-y: auto;
        padding-right: 4px;
    }

        .review-list::-webkit-scrollbar {
            width: 6px;
        }

        .review-list::-webkit-scrollbar-thumb {
            background-color: #d0d5dd;
            border-radius: 10px;
        }

    .object-fit-cover {
        object-fit: cover;
    }
</style>

<div class="col-12 col-lg-6 col-xl-6 d-flex">
    <div class="card rounded-4 w-100 border-0 shadow-sm">
        <div class="card-header bg-transparent border-0 p-4 pb-2">
            <div class="d-flex align-items-center justify-content-between">
                <div>
                    <h5 class="mb-1 fw-bold">💬 Müşteri Yorumları</h5>
                    <p class="text-muted mb-0 small">Kullanıcılardan gelen son yorumlar</p>
                </div>
                <span class="badge bg-primary-subtle text-primary rounded-pill px-3 py-2">
                    @Model.Count yorum
                </span>
            </div>
        </div>

        <div class="card-body p-4 pt-2">
            <div class="review-list">

                @foreach (var item in Model)
                {
                    <div class="review-card p-3 mb-3 rounded-4 border bg-light-subtle">
                        <div class="d-flex align-items-start gap-3">

                            <img src="@item.AppUser.ImageUrl"
                                 width="58"
                                 height="58"
                                 class="rounded-circle border shadow-sm object-fit-cover"
                                 alt="user">

                            <div class="flex-grow-1">

                                <div class="d-flex align-items-start justify-content-between mb-2">

                                    <div>
                                        <h6 class="mb-0 fw-semibold">
                                            @item.AppUser.Name @item.AppUser.Surname
                                        </h6>
                                        <span class="text-muted small">
                                            @item.CommentDate.ToString("dd MMM yyyy")
                                        </span>
                                    </div>

                                 
                                    @{
                                        string badgeClass = "";
                                        string badgeText = "";

                                        if (item.CommentStatus == "Yorum Onaylandı")
                                        {
                                            badgeClass = "bg-success-subtle text-success";
                                            badgeText = "✔ Onaylandı";
                                        }
                                        else if (item.CommentStatus == "Onay Bekliyor")
                                        {
                                            badgeClass = "bg-warning-subtle text-warning";
                                            badgeText = "⏳ Bekliyor";
                                        }
                                        else if (item.CommentStatus == "Toksik Yorum")
                                        {
                                            badgeClass = "bg-danger-subtle text-danger";
                                            badgeText = "⚠ Toksik";
                                        }
                                    }

                                    <span class="badge @badgeClass rounded-pill px-3 py-2">
                                        @badgeText
                                    </span>

                                </div>

                                <p class="mb-0 text-secondary small lh-base">
                                    @item.CommentDetail
                                </p>

                            </div>

                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>