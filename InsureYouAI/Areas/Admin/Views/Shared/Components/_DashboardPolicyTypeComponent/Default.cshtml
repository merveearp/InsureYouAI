@using InsureYouAI.Areas.Admin.Models
@model List<PolicyTypeModel>
@*
   _DashboardPolicyTypeComponent
*@


<div class="col-12 col-lg-6 col-xl-6 d-flex">
    <div class="card rounded-4 w-100">

        <div class="card-header bg-transparent border-0 pt-4 px-4">

            <div class="d-flex align-items-center justify-content-between">

                <div>
                    <h5 class="mb-1 fw-bold">
                        📊 Poliçe Tür Dağılımı
                    </h5>

                    <p class="text-muted mb-0 small">
                        Poliçe kategorilerine göre satış dağılım analizi
                    </p>
                </div>

                <div class="fs-2 text-primary">
                    <i class="bi bi-pie-chart-fill"></i>
                </div>

            </div>

        </div>

        <div class="card-body policy-scroll-area">

         @foreach (var item in Model)
{
    string emoji = item.PolicyType switch
    {
        "DASK" => "🏢",
        "Hayat" => "❤️",
        "İşyeri" => "🏬",
        "Kasko" => "🚗",
        "Konut" => "🏠",
        "Sağlık" => "🩺",
        "Seyahat" => "✈️",
        "Tamamlayıcı Sağlık" => "💊",
        "Trafik" => "🚦",
        _ => "📄"
    };

    <div class="d-flex align-items-start gap-3">

        <div class="policy-emoji-box">
            @emoji
        </div>

        <div class="flex-grow-1">
            <div class="progress-wrapper">

                <p class="my-2">
                    @item.PolicyType

                    <span class="float-end">
                        (@item.Count Poliçe Satışı)

                        <span class="ms-3 fw-bold">
                            @item.Rate%
                        </span>
                    </span>
                </p>

                <div class="progress" style="height: 6px;">
                    <div class="progress-bar bg-primary"
                         role="progressbar"
                         style="width:@(item.Rate.ToString(System.Globalization.CultureInfo.InvariantCulture))%">
                    </div>
                </div>

            </div>
        </div>

    </div>

    <hr />
}
            </div>

        </div>
    </div>