@model List<Comment>
@{
    ViewData["Title"] = "Yorum Listesi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
    int count = 0;
}



<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">

            <h5 class="mb-0 fw-bold text-primary">
                📩 Sigorta Makaleleri Kullanıcı Yorumları
            </h5>

            <div>

                <a href="/Admin/Comment/CommentList"
                       class="btn btn-sm btn-outline-dark me-1">
                    <i class="bi bi-list"></i> Tümü
                </a>

            </div>

        </div>

        <div class="table-responsive">

            <table class="table table-striped table-hover align-middle">

                <thead class="table-light">
                    <tr>
                        <th style="width:60px">#</th>
                        <th>Ad Soyad</th>
                        <th>Makale</th>
                        <th>Tarih</th>
                        <th>Onayla</th>
                        <th>Yorumu Kaldır</th>
                        <th>Onay Bekliyor</th>
                        <th>Sil</th>
                       
                    </tr>
                </thead>

                <tbody>

                    @if (Model != null && Model.Any())
                    {
                        foreach (var item in Model)
                        {
                            count++;

                            <tr>

                                <td>@count</td>

                                <td class="fw-semibold">
                                    @item.AppUser.Name @item.AppUser.Surname
                                </td>

                                <td>
                                    <i class="bi bi-envelope text-primary me-1"></i>
                                    @item.Article.Title
                                </td>


                                <td>
                                    <i class="bi bi-envelope text-primary me-1"></i>
                                  Toksik Yorum
                                </td>

                                <td>
                                    <i class="bi bi-telephone text-primary me-1"></i>
                                    @item.CommentDate.ToString("dd-MMM-yyyy")
                                </td>

                              

                                <td>
                                    @(string.IsNullOrEmpty(item.CommentDetail)
                                                                ? "-"
                                                                : item.CommentDetail.Length > 80
                                                                ? item.CommentDetail.Substring(0, 80) + "..."
                                                                : item.CommentDetail)
                                </td>


                                <td>

                                    <a href="/Admin/Comment/Delete/@item.CommentId"
                                           class="btn btn-sm btn-outline-dark me-1">
                                        <i class="bi bi-eye">Onayla</i>
                                    </a>

                                </td>
                                <td>

                                     
                                    <a href="/Admin/Comment/Delete/@item.CommentId"
                                           class="btn btn-sm btn-outline-dark me-1">
                                        <i class="bi bi-eye">Yorumu Kaldır</i>
                                    </a>

                                </td>
                                <td>

                                 
                                     
                                    <a href="/Admin/Comment/Delete/@item.CommentId"
                                           class="btn btn-sm btn-outline-dark me-1">
                                        <i class="bi bi-eye">Onay Bekliyor</i>
                                    </a>

                                </td>
                                <td>

                                   
                                    <a href="/Admin/Comment/Delete/@item.CommentId"
                                           class="btn btn-sm btn-outline-danger"
                                           onclick="return confirm('Bu mesajı silmek istediğinize emin misiniz?')">
                                        <i class="bi bi-trash"></i>
                                    </a>

                                </td>


                            </tr>
                        }
                    }

                    else
                    {
                        <tr>
                            <td colspan="9" class="text-center text-muted py-4">

                                <i class="bi bi-info-circle fs-4"></i>

                                <p class="mt-2">
                                    Henüz yorum bulunmamaktadır.
                                </p>

                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>

    </div>
</div>