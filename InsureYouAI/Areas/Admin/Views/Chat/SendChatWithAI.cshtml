@{
    ViewData["Title"] = "SendChatWithAI";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<link href="https://fonts.googleapis.com/css2?family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet" />

<style>
  .ai-chat-wrap { font-family: 'DM Sans', sans-serif; width: 100%; padding: 1.25rem; box-sizing: border-box; }
  .ai-chat-header { display: flex; align-items: center; gap: 10px; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid #e5e7eb; }
  .ai-chat-header-icon { width: 32px; height: 32px; background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
  .ai-chat-header-info h2 { font-size: 14px; font-weight: 500; margin: 0; color: #111; }
  .ai-chat-header-info p { font-size: 12px; color: #6b7280; margin: 0; }
  .ai-status-dot { width: 6px; height: 6px; background: #6b7280; border-radius: 50%; display: inline-block; margin-right: 4px; vertical-align: middle; }
  .ai-chat-window { background: #fff; border: 1px solid #e5e7eb; border-radius: 12px; min-height: 360px; max-height: 500px; overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 6px; scrollbar-width: thin; }
  .ai-chat-window:empty::before { content: "Yapay zeka ile konuşmaya başlayın..."; color: #9ca3af; font-size: 13px; display: block; text-align: center; margin-top: 140px; }
  .ai-msg-row { display: flex; gap: 8px; align-items: flex-end; animation: aiMsgIn .18s ease; }
  .ai-msg-row.user { flex-direction: row-reverse; }
  @@keyframes aiMsgIn { from { opacity:0; transform:translateY(5px); } to { opacity:1; transform:translateY(0); } }
  .ai-avatar { width: 26px; height: 26px; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-size: 10px; font-weight: 600; flex-shrink: 0; }
  .ai-avatar.bot { background: #f3f4f6; border: 1px solid #e5e7eb; color: #6b7280; }
  .ai-avatar.usr { background: #dbeafe; color: #1e40af; }
  .ai-bubble { max-width: 70%; padding: 8px 12px; border-radius: 14px; font-size: 13.5px; line-height: 1.55; word-break: break-word; }
  .ai-msg-row.user .ai-bubble { background: #185FA5; color: #fff; border-bottom-right-radius: 4px; }
  .ai-msg-row.bot .ai-bubble { background: #f3f4f6; color: #111; border-bottom-left-radius: 4px; border: 1px solid #e5e7eb; }
  .ai-typing-row { display: none; align-items: flex-end; gap: 8px; margin-top: 2px; }
  .ai-typing-row.on { display: flex; }
  .ai-typing-dots { background: #f3f4f6; border: 1px solid #e5e7eb; border-radius: 14px; border-bottom-left-radius: 4px; padding: 10px 14px; display: flex; gap: 4px; align-items: center; }
  .ai-typing-dots span { width: 5px; height: 5px; border-radius: 50%; background: #9ca3af; animation: aiBounce 1.2s infinite; display: block; }
  .ai-typing-dots span:nth-child(2) { animation-delay:.15s; }
  .ai-typing-dots span:nth-child(3) { animation-delay:.3s; }
  @@keyframes aiBounce { 0%,80%,100%{transform:translateY(0);opacity:.4;} 40%{transform:translateY(-5px);opacity:1;} }
  .ai-input-row { display: flex; gap: 8px; margin-top: 10px; }
  .ai-input-row input[type="text"] { flex: 1; padding: 9px 13px; font-family: inherit; font-size: 13.5px; border: 1px solid #d1d5db; border-radius: 10px; outline: none; color: #111; background: #fff; transition: border-color .15s, box-shadow .15s; }
  .ai-input-row input[type="text"]:focus { border-color: #378ADD; box-shadow: 0 0 0 3px rgba(55,138,221,.12); }
  .ai-send-btn { width: 38px; height: 38px; flex-shrink: 0; border: none; border-radius: 10px; background: #185FA5; color: #fff; cursor: pointer; display: flex; align-items: center; justify-content: center; transition: background .15s, transform .1s; }
  .ai-send-btn:hover { background: #378ADD; }
  .ai-send-btn:active { transform: scale(.95); }
  .ai-footer { margin-top: 7px; display: flex; justify-content: space-between; align-items: center; }
  .ai-footer-hint { font-size: 11px; color: #9ca3af; }
  .ai-clear-btn { font-size: 11px; color: #9ca3af; background: none; border: none; cursor: pointer; padding: 2px 6px; border-radius: 4px; }
  .ai-clear-btn:hover { background: #f3f4f6; color: #374151; }
</style>

<div class="ai-chat-wrap">

  <div class="ai-chat-header">
    <div class="ai-chat-header-icon">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <circle cx="12" cy="12" r="10"/><path d="M12 16v-4m0-4h.01"/>
      </svg>
    </div>
    <div class="ai-chat-header-info">
      <h2>Yapay Zeka Asistanı</h2>
      <p><span class="ai-status-dot" id="aiStatusDot"></span><span id="aiStatusText">Bağlanıyor...</span></p>
    </div>
  </div>

  <div class="ai-chat-window" id="aiChat"></div>

  <div class="ai-typing-row" id="aiTypingRow">
    <div class="ai-avatar bot">AI</div>
    <div class="ai-typing-dots"><span></span><span></span><span></span></div>
  </div>

  <div class="ai-input-row">
    <input id="aiInput" type="text" placeholder="Mesajınızı yazın..." autocomplete="off" />
    <button class="ai-send-btn" id="aiSendBtn">
      <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="#fff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
        <line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>
      </svg>
    </button>
  </div>

  <div class="ai-footer">
    <span class="ai-footer-hint">Enter ile gönder &middot; SignalR gerçek zamanlı</span>
    <button class="ai-clear-btn" id="aiClearBtn">Sohbeti temizle</button>
  </div>

</div>

<script src="https://cdn.jsdelivr.net/npm/@@microsoft/signalr@8.0.0/dist/browser/signalr.min.js"></script>
<script src="https://cdn.jsdelivr.net/npm/marked/marked.min.js"></script>
<script>
  const aiChat      = document.getElementById('aiChat');
  const aiTyping    = document.getElementById('aiTypingRow');
  const aiInput     = document.getElementById('aiInput');
  const aiSendBtn   = document.getElementById('aiSendBtn');
  const aiClearBtn  = document.getElementById('aiClearBtn');
  const aiStatusDot = document.getElementById('aiStatusDot');
  const aiStatusTxt = document.getElementById('aiStatusText');
  let bufBubble = null;

  function mkAvatar(type) {
    const el = document.createElement('div');
    el.className = `ai-avatar ${type}`;
    el.textContent = type === 'usr' ? 'SİZ' : 'AI';
    return el;
  }

  function addUser(text) {
    const row = document.createElement('div');
    row.className = 'ai-msg-row user';
    const b = document.createElement('div');
    b.className = 'ai-bubble';
    b.textContent = text;
    row.appendChild(b);
    row.appendChild(mkAvatar('usr'));
    aiChat.appendChild(row);
    aiChat.scrollTop = aiChat.scrollHeight;
  }

  function startBot() {
    const row = document.createElement('div');
    row.className = 'ai-msg-row bot';
    row.appendChild(mkAvatar('bot'));
    const b = document.createElement('div');
    b.className = 'ai-bubble';
    row.appendChild(b);
    aiChat.appendChild(row);
    bufBubble = b;
  }

  const conn = new signalR.HubConnectionBuilder()
    .withUrl("/chathub")
    .withAutomaticReconnect()
    .build();

  conn.on("ReceiveUserEcho", text => addUser(text));

  conn.on("ReceiveToken", token => {
  aiTyping.classList.add('on');
  if (!bufBubble) startBot();
  const raw = (bufBubble.dataset.raw || '') + token;
  bufBubble.dataset.raw = raw;
  bufBubble.innerHTML = marked.parse(raw);
  aiChat.scrollTop = aiChat.scrollHeight;
});

  conn.on("CompleteMessage", () => {
    aiTyping.classList.remove('on');
    bufBubble = null;
  });

  async function start() {
    try {
      await conn.start();
      aiStatusDot.style.background = '#3B6D11';
      aiStatusTxt.textContent = 'Bağlı · SignalR';
    } catch {
      aiStatusDot.style.background = '#dc2626';
      aiStatusTxt.textContent = 'Bağlantı hatası';
      setTimeout(start, 1500);
    }
  }
  start();

  async function send() {
    const text = aiInput.value.trim();
    if (!text) return;
    aiInput.value = '';
    bufBubble = null;
    aiTyping.classList.add('on');
    await conn.invoke("SendMessage", text);
  }

  aiClearBtn.addEventListener('click', () => {
    aiChat.innerHTML = '';
    bufBubble = null;
    aiTyping.classList.remove('on');
  });

  aiSendBtn.addEventListener('click', send);
  aiInput.addEventListener('keydown', e => { if (e.key === 'Enter') send(); });
</script>