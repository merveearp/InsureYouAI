@model List<Contact>
@{
    ViewData["Title"] = "İletişim Sayfası";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="mb-0 fw-bold text-primary">
                📂 İletişim Sayfası
            </h5>

            <a href="/Admin/Contact/Create" class="btn btn-outline-primary">
                + Yeni İletişim Bilgisi Ekle
            </a>
        </div>

        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="row align-items-center border-bottom pb-4 mb-4">

                    <div class="col-md-8">

                        <h5 class="fw-bold mb-3">
                            <i class="bi bi-info-circle text-primary me-2"></i>
                            @item.Desciption
                        </h5>

                        <p class="mb-2">
                            <i class="bi bi-envelope text-primary me-2"></i>
                            <span class="text-muted">@item.Email</span>
                        </p>

                        <p class="mb-2">
                            <i class="bi bi-telephone text-primary me-2"></i>
                            <span class="text-muted">@item.PhoneNumber</span>
                        </p>

                        <p class="mb-3">
                            <i class="bi bi-geo-alt text-primary me-2"></i>
                            <span class="text-muted">@item.Address</span>
                        </p>

                        <div class="mt-3">

                            <a href="/Admin/Contact/Update/@item.ContactId"
                               class="btn btn-sm btn-outline-success me-2">
                                <i class="bi bi-pencil-square"></i> Güncelle
                            </a>

                            <a href="/Admin/Contact/Delete/@item.ContactId"
                               class="btn btn-sm btn-outline-danger"
                               onclick="return confirm('Bu iletişim bilgisini silmek istediğinize emin misiniz?')">
                                <i class="bi bi-trash"></i> Sil
                            </a>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="text-center text-muted py-5">

                <i class="bi bi-info-circle fs-3"></i>

                <p class="mt-3">
                    Henüz iletişim bilgisi bulunmamaktadır.
                </p>

                <a href="/Admin/Contact/Create"
                   class="btn btn-primary btn-sm mt-2">
                    İlk İçeriği Ekle
                </a>

            </div>
        }

    </div>
</div>