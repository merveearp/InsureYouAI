@model Contact
@{
    ViewData["Title"] = "İletişim Bilgisi Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                ✏️ İletişim Bilgisi Güncelle
            </h5>
        </div>

        <form method="post">

            <input type="hidden" asp-for="ContactId" />

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Açıklama
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-info-circle"></i>
                    </span>

                    <input type="text"
                           asp-for="Desciption"
                           class="form-control"
                           required />
                </div>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Email Adresi
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-envelope"></i>
                    </span>

                    <input type="email"
                           asp-for="Email"
                           class="form-control"
                           required />
                </div>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Telefon Numarası
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-telephone"></i>
                    </span>

                    <input type="tel"
                           asp-for="PhoneNumber"
                           class="form-control"
                           required />
                </div>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Adres
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-geo-alt"></i>
                    </span>

                    <input type="text"
                           asp-for="Address"
                           class="form-control"
                           required />
                </div>
            </div>


            <div class="d-flex gap-2 mt-3">

                <a href="/Admin/Contact/Index"
                   class="btn btn-outline-danger">
                    Vazgeç
                </a>

                <button class="btn btn-outline-success px-4">
                    Güncelle
                </button>

            </div>

        </form>

    </div>
</div>