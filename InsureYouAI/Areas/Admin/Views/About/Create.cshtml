@model About
@{
    ViewData["Title"] = "Yeni Hakkımızda Ekle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                📂 Yeni Hakkımızda Yazı Girişi
            </h5>
        </div>

        <button type="button" id="generateAI" class="btn btn-primary">
            ✨ AI İçerik Oluştur
        </button>

        <form method="post">

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Başlık
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-tag"></i>
                    </span>
                    <input type="text"
                           asp-for="Title"
                           class="form-control"
                           placeholder="Hakkımda Başlığı"
                           required />
                </div>

                <small class="text-muted">
                    Hakkımızda başlığını açık ve anlaşılır şekilde giriniz.
                </small>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Açıklama
                </label>

                <textarea asp-for="Description"
                          class="form-control"
                          rows="10"
                          placeholder="Hakkımızda açıklaması"></textarea>

                <small class="text-muted">
                    Hakkımızda açıklamasını detaylı şekilde giriniz.
                </small>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Hakkımızda Görsel
                </label>
                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-image"></i>
                    </span>

                    <input type="text"
                           asp-for="ImageUrl"
                           id="imageUrlInput"
                           class="form-control"
                           placeholder="https://site.com/image.jpg"
                           required />
                </div>

                <div class="mt-3">
                    <img id="imagePreview"
                         src=""
                         class="shadow-sm border"
                         style="max-width:250px; display:none;" />
                </div>

                <small class="text-muted">
                    Hakkımızda görselini link olarak ekleyiniz.
                </small>
            </div>

            <div class="d-flex justify-content-start gap-2 mt-3">

                <a href="/Admin/About/AboutList"
                   class="btn btn-outline-danger">
                    Vazgeç
                </a>

                <button class="btn btn-outline-primary px-4">
                    Kaydet
                </button>

            </div>

        </form>

    </div>
</div>

<script>

    document.getElementById("generateAI").onclick = function () {

        const btn = this;

        btn.innerText = "AI içerik hazırlanıyor...";
        btn.disabled = true;

        fetch('/Admin/About/GenerateAbout')
            .then(response => response.json())
            .then(data => {

                document.getElementById("Title").value = data.title;
                document.getElementById("Description").value = data.description;

                btn.innerText = "🔄 Tekrar Oluştur";
                btn.disabled = false;

            })
            .catch(() => {

                btn.innerText = "✨ AI İçerik Oluştur";
                btn.disabled = false;

                alert("AI içerik oluşturulamadı.");

            });

    };

</script>

<script>

    const imageInput = document.getElementById("imageUrlInput");
    const preview = document.getElementById("imagePreview");

    const defaultUrl = "/images/default-image.jpg";

    preview.src = defaultUrl;
    preview.style.display = "block";

    imageInput.addEventListener("input", function () {

        const url = this.value;

        if (url.length > 0) {
            preview.src = url;
        }
        else {
            preview.src = defaultUrl;
        }

    });

</script>