@model About
@{
    ViewData["Title"] = "Hakkımızda Güncelle";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-3">
            <h5 class="mb-0 fw-bold text-primary">
                📂 Hakkımızda Yazı Düzenleme Sayfası
            </h5>
        </div>
        <button type="button" id="generateAI" class="btn btn-warning">
            ✨ AI ile Hakkımızda İçeriği Üret
        </button>
        <br />


        <form method="post">

            <input type="hidden" asp-for="AboutId" />

            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Başlık
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-tag"></i>
                    </span>

                    <input type="text"
                           asp-for="Title"
                           class="form-control"
                           placeholder="Hakkımda Başlığı"
                           required />
                </div>

                <small class="text-muted">
                    Başlığı açık ve anlaşılır şekilde düzenleyiniz.
                </small>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Açıklama
                </label>

                <textarea asp-for="Description"
                          class="form-control"
                          rows="5"
                          placeholder="Hakkımızda açıklaması"></textarea>

                <small class="text-muted">
                    Hakkımızda açıklamasını düzenleyiniz.
                </small>
            </div>


            <div class="mb-3">
                <label class="form-label fw-semibold">
                    Hakkımızda Görsel
                </label>

                <div class="input-group">
                    <span class="input-group-text bg-light">
                        <i class="bi bi-image"></i>
                    </span>

                    <input type="text"
                           asp-for="ImageUrl"
                           id="imageUrlInput"
                           class="form-control"
                           placeholder="/images/about/about1.jpg"
                           required />
                </div>

                <div class="mt-3">
                    <img id="imagePreview"
                         src=""
                         class="shadow-sm border rounded"
                         style="max-width:250px;" />
                </div>

                <small class="text-muted">
                    Hakkımızda görselini link olarak güncelleyiniz.
                </small>
            </div>


            <div class="d-flex justify-content-start gap-2">

                <a href="/Admin/About/AboutList"
                   class="btn btn-outline-danger">
                    Vazgeç
                </a>

                <button class="btn btn-outline-success px-4">
                    Güncelle
                </button>

            </div>

        </form>

    </div>
</div>
<script>

    document.getElementById("generateAI").onclick = function () {

        const btn = this;

        btn.innerText = "AI içerik hazırlanıyor...";
        btn.disabled = true;

        fetch('/Admin/About/GenerateAbout')
            .then(res => res.json())
            .then(data => {

                document.getElementById("Title").value = data.title;
                document.getElementById("Description").value = data.description;

                btn.innerText = "🔄 Tekrar Üret";
                btn.disabled = false;

            })
            .catch(() => {

                btn.innerText = "✨ AI ile İçerik Üret";
                btn.disabled = false;

                alert("AI içerik oluşturulamadı.");

            });

    };

</script>

<script>

    const imageInput = document.getElementById("imageUrlInput");
    const preview = document.getElementById("imagePreview");

    const defaultUrl = "/images/default-image.jpg";

    preview.src = imageInput.value ? imageInput.value : defaultUrl;

    imageInput.addEventListener("input", function () {

        const url = this.value;

        if (url.length > 0) {
            preview.src = url;
        }
        else {
            preview.src = defaultUrl;
        }

    });

</script>


