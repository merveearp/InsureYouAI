@model List<About>
@{
    ViewData["Title"] = "Hakkımızda";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}

<div class="card shadow-sm border-0 rounded-3">
    <div class="card-body">

        <div class="d-flex justify-content-between align-items-center mb-4">
            <h5 class="mb-0 fw-bold text-primary">
                📂 Hakkımızda Sayfası
            </h5>

            <a href="/Admin/About/Create" class="btn btn-outline-primary">
                + Yeni Hakkımızda Bilgisi Ekle
            </a>
        </div>


        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <div class="row align-items-center">

                    <div class="col-md-4">

                        <img src="@item.ImageUrl"
                             class="img-fluid rounded shadow-sm border"
                             style="max-height:250px; object-fit:cover;" />

                    </div>

                    <div class="col-md-8">

                        <h4 class="fw-bold mb-3">
                            @item.Title
                        </h4>

                        <p class="text-muted">
                            @item.Description
                        </p>

                        <div class="mt-4">

                            <a href="/Admin/About/Update/@item.AboutId"
                               class="btn btn-outline-success me-2">
                                <i class="bi bi-pencil-square"></i> Güncelle
                            </a>

                            <a href="/Admin/About/Delete/@item.AboutId"
                               class="btn btn-outline-danger"
                               onclick="return confirm('Bu Hakkımızda içeriğini silmek istediğinize emin misiniz?')">
                                <i class="bi bi-trash"></i> Sil
                            </a>

                        </div>

                    </div>

                </div>
            }
        }
        else
        {
            <div class="text-center text-muted py-5">

                <i class="bi bi-info-circle fs-3"></i>

                <p class="mt-3">
                    Henüz Hakkımızda içeriği bulunmamaktadır.
                </p>

                <a href="/Admin/About/Create"
                   class="btn btn-primary btn-sm mt-2">
                    İlk İçeriği Ekle
                </a>

            </div>
        }

    </div>
</div>