@model AppUser
@{
    ViewData["Title"] = "Kullanıcı Yorum Analizi";
    Layout = "~/Areas/Admin/Views/Shared/_Layout.cshtml";
}


<style>

    .author-card {
        transition: all 0.3s ease;
    }

        .author-card:hover {
            transform: translateY(-6px);
        }

    .stat-box {
        transition: all 0.3s ease;
        border: 1px solid #f1f1f1;
    }

        .stat-box:hover {
            background-color: #ffffff !important;
            box-shadow: 0 8px 20px rgba(0,0,0,0.08);
        }

    .about-box {
        border: 1px solid #f1f1f1;
    }

    .profile-avatar img {
        object-fit: cover;
    }
</style>
 
<div class="profile-cover bg-dark"></div>
<div class="row">
    <div class="col-12 col-lg-8">
        <div class="card shadow-sm border-0">
            <div class="card-body">
                <h5 class="mb-0">Kullanıcı AI Analiz Detayları</h5>
                <hr>
                <div class="card shadow-none border">
                    <div class="card-header">
                        <h6 class="mb-0">Kullanıcı Yorum AI Analizi</h6>
                    </div>
                    <div class="card-body">
                        <pre style="white-space :pre-wrap ; font-size:15px">@ViewBag.AIResult</pre>

                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-12 col-lg-4">
        <div class="card border-0 shadow-lg rounded-4 overflow-hidden author-card">
        
            <div class="card-header border-0 text-center py-4 bg-light">
                <div class="profile-avatar position-relative d-inline-block">
                    <img src="@Model.ImageUrl"
                         class="rounded-circle shadow border border-4 border-white"
                         width="130"
                         height="130"
                         style="object-fit:cover;"
                         alt="@Model.Name @Model.Surname">

                    <span class="position-absolute bottom-0 end-0 bg-success rounded-circle p-2 border border-3 border-white"></span>
                </div>

                <div class="mt-3">
                    <h3 class="fw-bold mb-1 text-dark">@Model.Name @Model.Surname</h3>
                    <p class="text-muted mb-0">
                        <i class="bi bi-geo-alt-fill me-1 text-danger"></i>@Model.City
                    </p>
                </div>
            </div>

            <div class="card-body p-4">
            
                <div class="text-center mb-4">
                    <span class="badge rounded-pill bg-primary-subtle text-primary px-3 py-2 fs-6">
                        <i class="bi bi-mortarboard-fill me-1"></i>@Model.Education
                    </span>
                </div>

                <div class="row g-3 text-center mb-4">
                    <div class="col-6">
                        <div class="stat-box p-3 rounded-4 bg-light h-100">
                            <div class="icon-box mb-2">
                                <i class="bi bi-file-earmark-text-fill fs-2 text-primary"></i>
                            </div>
                            <h6 class="text-muted mb-1">Blog Yazısı</h6>
                            <h4 class="fw-bold mb-0 text-dark">@ViewBag.Count</h4>
                        </div>
                    </div>

                    <div class="col-6">
                        <div class="stat-box p-3 rounded-4 bg-light h-100">
                            <div class="icon-box mb-2">
                                <i class="bi bi-chat-dots-fill fs-2 text-success"></i>
                            </div>
                            <h6 class="text-muted mb-1">Yorum Sayısı</h6>
                            <h4 class="fw-bold mb-0 text-dark">@Model.Comments.Count()</h4>
                        </div>
                    </div>
                </div>

                <div class="about-box p-3 rounded-4 bg-light">
                    <div class="d-flex align-items-center mb-2">
                        <i class="bi bi-person-badge-fill fs-4 text-warning me-2"></i>
                        <h5 class="fw-bold mb-0 text-dark">Hakkında</h5>
                    </div>

                    <p class="text-secondary mb-0" style="line-height:1.8;">
                        @Model.Description
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>


       


